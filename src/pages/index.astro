---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import ContributionChart from "../components/ContributionChart.astro";
import { resolveImageSource } from "../assets/images";
import { type CollectionEntry, getCollection } from "astro:content";

const workStyle = [
  "先判断值不值得做，再拆最短闭环，尽快把产品推到可验证状态。",
  "把开发、上线、日志、备份和恢复一起做完，减少后续维护成本。",
];

const deliveryPoints = [
  "独立完成从需求梳理、开发实现到部署上线。",
  "把 AI 用进编码、排障、文档和资料整理，直接换交付速度。",
  "提前处理模块边界、发布流程、日志和备份，避免项目上线后失控。",
  "能补齐模型接入、Token 中转和算力接入这类工程支持环节。",
];

type ProjectEntry = CollectionEntry<"projects">;

const projects = await getCollection("projects");
const homeProjectSlugs = ["sxeasy"];
const homeProjects: ProjectEntry[] = homeProjectSlugs.flatMap((slug) => {
  const project = projects.find((entry) => entry.slug === slug);
  return project ? [project] : [];
});

const getProjectUrl = (project: ProjectEntry): string => {
  if (project.data.detailPage) {
    return `/projects/${project.slug}`;
  }

  if (project.data.externalUrl) {
    return project.data.externalUrl;
  }

  throw new Error(`Project "${project.slug}" is missing externalUrl while detailPage is false.`);
};

const getProjectImageLight = (project: ProjectEntry) =>
  resolveImageSource(
    project.data.coverImageLight
      ?? project.data.coverImage
      ?? project.data.heroImageLight
      ?? project.data.heroImage,
  );
const getProjectImageDark = (project: ProjectEntry) =>
  resolveImageSource(
    project.data.coverImageDark
      ?? project.data.coverImage
      ?? project.data.heroImageDark
      ?? project.data.heroImage,
  );
---

<BaseLayout
  description="张永鑫的个人作品集，展示全栈产品开发、项目交付、AIGC 工程接入和可持续维护能力。"
  sideBarActiveItemID="home"
>
  <div class="mt-2 pb-12 sm:mt-4 sm:pb-14 lg:mt-6 lg:pb-16">
    <div class="py-1 text-lg sm:text-xl">你好 👋</div>
    <div class="text-3xl font-bold leading-tight sm:text-5xl lg:text-7xl">我是 张永鑫</div>
    <div class="py-3 text-xl font-bold leading-tight sm:text-3xl lg:text-5xl">Ethan Zhang · 全栈产品开发</div>
    <div class="max-w-4xl py-2">
      <p class="text-base leading-7 sm:text-lg sm:leading-relaxed lg:text-[1.95rem] lg:leading-[1.5]">
        把想法做成能上线、能验证、能继续迭代的产品。
      </p>
    </div>
    <div class="mt-8 flex flex-col gap-3 sm:mt-10 sm:flex-row sm:flex-wrap sm:gap-4 lg:mt-12">
      <a class="btn w-full sm:w-auto sm:min-w-[12rem]" href="/contact">联系我</a>
      <a href="#delivery" class="btn btn-outline w-full sm:w-auto sm:min-w-[14rem]">
        交付能力
      </a>
    </div>
  </div>

  <section class="mb-14">
    <div class="max-w-4xl">
      <div class="mb-4 text-2xl font-bold leading-tight sm:text-3xl lg:text-4xl">工作方式</div>
      <div class="mt-5 grid max-w-4xl gap-3 leading-7 opacity-80">
        {workStyle.map((item) => <p>{item}</p>)}
      </div>
    </div>
  </section>

  <section id="delivery" class="mb-16 scroll-mt-8 lg:scroll-mt-12">
    <div class="max-w-4xl">
      <div class="mb-4 text-2xl font-bold leading-tight sm:text-3xl lg:text-4xl">交付能力</div>
      <div class="mt-5 grid max-w-4xl gap-3 leading-7 opacity-80">
        {deliveryPoints.map((item) => <p>{item}</p>)}
      </div>
    </div>
  </section>

  <ContributionChart />

  <div>
    <div class="mb-2 w-full text-2xl font-bold sm:text-3xl lg:text-5xl">近期项目 {"</>"}</div>
  </div>

  {
    homeProjects.map((project, index) => (
      <>
        <HorizontalCard
          title={project.data.title}
          imgLight={getProjectImageLight(project)}
          imgDark={getProjectImageDark(project)}
          desc={project.data.description}
          url={getProjectUrl(project)}
          badge={project.data.badge}
          target={project.data.detailPage ? "_self" : "_blank"}
        />
        {index < homeProjects.length - 1 && <div class="divider my-0" />}
      </>
    ))
  }
</BaseLayout>
