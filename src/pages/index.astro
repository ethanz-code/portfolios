---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import ContributionChart from "../components/ContributionChart.astro";
import { getContentEntryPath } from "../lib/content-routes";
import { type CollectionEntry, getCollection } from "astro:content";
import aiDesignEffectDisplayImage from "../assets/projects/ai-design-aigc/effect-display.webp";
import newlandKnowledgeBaseDarkImage from "../assets/projects/newland-iot-technical-services/knowledge-base-dark.webp";
import newlandKnowledgeBaseImage from "../assets/projects/newland-iot-technical-services/knowledge-base.webp";
import sxeasyHomeImage from "../assets/projects/sxeasy/home.webp";
import sxeasyHomeDarkImage from "../assets/projects/sxeasy/home-dark.webp";

const workStyle = [
  "先确认用户、场景和成本，再拆最短闭环，把产品推到可验证状态。",
  "上线前补齐日志、监控、备份和恢复方案，确保问题能发现、能回退。",
];

const deliveryPoints = [
  "能够独立完成从需求梳理、开发实现到部署上线。",
  "有多人协同开发经验，能够很好的沟通和配合，推动项目进展。",
  "会用主流 AI 提高开发效率，但同时也会确保实际效果和可持续维护。必要时刻也能够帮助团队搭建 Token 中转服务。",
  "我并不会造轮子，比如说要我做克隆数字人，我并不会对于模型的开发训练相关技能，我最多只能帮忙去对接现有以及开源的模式去用。",
];

type ProjectEntry = CollectionEntry<"projects">;

const projects = await getCollection("projects");
const homeProjects: ProjectEntry[] = projects
  .filter((project) => project.data.category === "featured")
  .sort((a, b) => b.data.updatedDate.valueOf() - a.data.updatedDate.valueOf())
  .slice(0, 2);

const getProjectUrl = (project: ProjectEntry): string => {
  if (project.data.detailPage) {
    return getContentEntryPath("projects", project);
  }

  if (project.data.externalUrl) {
    return project.data.externalUrl;
  }

  throw new Error(`Project "${project.id}" is missing externalUrl while detailPage is false.`);
};

const getProjectImageLight = (project: ProjectEntry) =>
  project.id === "sxeasy"
    ? sxeasyHomeImage
    : project.id === "ai-design-aigc"
      ? aiDesignEffectDisplayImage
      : project.id === "newland-iot-technical-services"
        ? newlandKnowledgeBaseImage
        : project.data.heroImageLight ?? project.data.heroImage;
const getProjectImageDark = (project: ProjectEntry) =>
  project.id === "sxeasy"
    ? sxeasyHomeDarkImage
    : project.id === "ai-design-aigc"
      ? aiDesignEffectDisplayImage
      : project.id === "newland-iot-technical-services"
        ? newlandKnowledgeBaseDarkImage
        : project.data.heroImageDark ?? project.data.heroImage;
---

<BaseLayout
  description="张永鑫的个人作品集，展示全栈产品开发、项目交付、成熟模型接入和可持续维护能力。"
  sideBarActiveItemID="home"
>
  <div class="mt-2 pb-12 sm:mt-4 sm:pb-14 lg:mt-6 lg:pb-16">
    <div class="py-1 text-lg sm:text-xl">你好 👋</div>
    <div class="text-3xl font-bold leading-tight sm:text-5xl lg:text-6xl">我是 张永鑫</div>
    <div class="py-3 text-xl font-bold leading-tight sm:text-3xl lg:text-4xl">Ethan Zhang · 全栈产品开发</div>
    <div class="max-w-4xl py-2">
      <p class="text-base leading-7 sm:text-lg sm:leading-relaxed lg:text-xl lg:leading-[1.6]">
        这是我的个人资料站点，在这里写一些自己的项目经历，技术积累以及所思所想。希望能让你对我有个更全面的了解。
      </p>
      <p class="mt-3 text-base leading-7 sm:text-lg sm:leading-relaxed lg:text-xl lg:leading-[1.6]">
        我做过知识库教程分享，做过中转站，也给自己当过客服。
      </p>
    </div>
    <div class="mt-8 flex flex-col gap-3 sm:mt-10 sm:flex-row sm:flex-wrap sm:gap-4 lg:mt-12">
      <a class="btn w-full sm:w-auto sm:min-w-[12rem]" href="/contact">联系我</a>
      <a href="#delivery" class="btn btn-outline w-full sm:w-auto sm:min-w-[14rem]">
        交付能力
      </a>
    </div>
    <div class="mt-4 text-sm leading-6 text-base-content/45">
      <a href="/new-tab" class="link-hover">New Tab</a>
    </div>
  </div>

  <section class="mb-14">
    <div class="max-w-4xl">
      <div class="mb-4 text-2xl font-bold leading-tight sm:text-3xl lg:text-4xl">工作方式</div>
      <div class="mt-5 grid max-w-4xl gap-3 leading-7 opacity-80">
        {workStyle.map((item) => <p>{item}</p>)}
      </div>
    </div>
  </section>

  <section id="delivery" class="mb-16 scroll-mt-8 lg:scroll-mt-12">
    <div class="max-w-4xl">
      <div class="mb-4 text-2xl font-bold leading-tight sm:text-3xl lg:text-4xl">交付能力</div>
      <div class="mt-5 grid max-w-4xl gap-4 leading-7">
        {
          deliveryPoints.map((item, index) => (
            <div class="flex gap-3">
              <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center bg-base-content text-xs font-bold leading-none text-base-100">
                {String(index + 1).padStart(2, "0")}
              </span>
              <p class="opacity-80">{item}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <ContributionChart />

  <section class="mb-16">
    <div class="mb-4 text-2xl font-bold leading-tight sm:text-3xl lg:text-4xl">近期项目 {"</>"}</div>
    <p class="mb-6 max-w-3xl leading-7 opacity-80">
      最近在维护、更新和继续投入的项目在这里噢。
    </p>
    <div class="w-full min-w-0 max-w-3xl">
      {
        homeProjects.map((project, index) => (
          <>
            <HorizontalCard
              title={project.data.title}
              imgLight={getProjectImageLight(project)}
              imgDark={getProjectImageDark(project)}
              desc={project.data.description}
              visitorDesc={project.data.visitorDescription}
              url={getProjectUrl(project)}
              target={project.data.detailPage ? "_self" : "_blank"}
            />
            {index < homeProjects.length - 1 && <div class="divider my-0" />}
          </>
        ))
      }
    </div>
  </section>
</BaseLayout>
