---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";

const skills = [
  "React",
  "Vue 3",
  "TypeScript",
  "Node.js",
  "Elysia",
  "Tailwind CSS",
  "Vite",
  "Prisma",
  "PostgreSQL",
  "Redis",
  "Docker",
  "Cloudflare Workers",
  "Prompt Engineering",
  "Data Analysis",
];
---

<BaseLayout title="简历" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">个人简介</div>
  </div>

  <div class="mb-10 grid gap-4 text-justify leading-8">
    <p>
      张永鑫（Ethan Zhang），山东。2022 年起深耕 Web 全栈，拥有企业执照。
      关注需求识别、上线交付和迭代增长。
    </p>
    <p>
      我重视生产级交付：需求清晰、边界明确、发布可控，
      日志、灰度、备份和恢复齐全。长期关注独立开发、增长运营、产品拆解和边缘计算。
    </p>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">核心亮点</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2 leading-7">
    <li>独立上线 AIGC 聊天与绘画平台，覆盖用户、充值、作品、后台和部署链路。</li>
    <li>完成老项目迁移、前后端重构、性能优化和上线流程整理。</li>
    <li>重视模块边界、接口契约、数据模型和部署流程，确保项目可持续迭代。</li>
    <li>开源项目“小红书短视频解析服务”获得 GitHub 80+ stars；物联网知识库累计 350+ 关注、10 万+ 浏览。</li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">项目经历</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement title="爱设计 AIGC · 全栈开发工程师" subtitle="2024 年 4 月 至 2024 年 6 月">
      独立完成 AIGC 聊天与绘画平台从 0 到 1 上线，负责用户系统、支付、作品管理、后台和部署，并按业务域拆分聊天、绘图、内容分发和管理端模块。
    </TimeLineElement>
    <TimeLineElement title="小红书短视频解析服务 · 开源项目" subtitle="GitHub 80+ stars">
      面向开发者的短视频解析工具，持续优化内容提取、部署体验和稳定性。
    </TimeLineElement>
    <TimeLineElement title="物联网竞赛知识库 · 内容与工具建设" subtitle="中职阶段至今">
      持续沉淀竞赛笔记，吸引 350+ 相关师生关注，累计浏览 10 万+。同时补充资料分发和支付能力，验证内容变现。
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">荣誉奖项</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement title="IITC 工信人才岗位能力评定证书" subtitle="2025，工业互联网平台开发工程师（中级）" />
    <TimeLineElement title="第十六届全国蓝桥杯" subtitle="2025，Web 应用开发职业院校组 · 二等奖" />
    <TimeLineElement title="第十六届山东省蓝桥杯" subtitle="2025，Web 应用开发职业院校组 · 一等奖" />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">技能</div>
  </div>

  <ul class="list-disc md:columns-4 columns-2 mx-6 mb-10">
    {skills.map((skill) => <li>{skill}</li>)}
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">长期关注</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>跟进全球主流技术、工程化实践和产品交付方法。</li>
    <li>关注中医健康、营养学和训练恢复，保持长期稳定状态。</li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">联系方式</div>
  </div>

  <ul class="list-disc mx-6 grid gap-2">
    <li>手机：<a href="tel:13198763535">13198763535</a></li>
    <li>QQ：<a href="https://wpa.qq.com/msgrd?v=3&uin=57878778&site=qq&menu=yes" target="_blank">57878778</a></li>
    <li>邮箱：<a href="mailto:hi@itcox.cn">hi@itcox.cn</a></li>
  </ul>
</BaseLayout>
