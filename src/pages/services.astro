---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="服务" sideBarActiveItemID="services">
  <div>
    <div class="text-3xl w-full font-bold mb-5">可提供的服务</div>
  </div>

  <HorizontalCard
    title="MVP 与可持续交付"
    img="/post_img.webp"
    desc="裁剪需求、拆分模块、快速上线，让产品先跑起来，再持续迭代。"
    badge="核心"
    url="mailto:hi@itcox.cn"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Web 全栈与架构整理"
    img="/post_img.webp"
    desc="用 TypeScript、Node.js、React/Vue、Prisma、数据库和缓存交付业务系统，并梳理边界与接口。"
    url="mailto:hi@itcox.cn"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="AIGC 应用接入"
    img="/post_img.webp"
    desc="接入聊天、绘图、多模态和流式响应，配套用户体系、作品管理和运营后台。"
    url="mailto:hi@itcox.cn"
    badge="AIGC"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="部署与线上排障"
    img="/post_img.webp"
    desc="处理 Docker、Nginx、CDN、WAF、多实例、CI/CD 和线上排障，让项目可定位、可恢复。"
    url="mailto:hi@itcox.cn"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="数据分析与增长运营"
    img="/post_img.webp"
    desc="梳理指标、路径和转化，把上线后的真实数据变成下一步决策。"
    url="mailto:hi@itcox.cn"
  />
</BaseLayout>
