---
import BaseLayout from "../layouts/BaseLayout.astro";

const contactItems = [
  {
    label: "手机号",
    value: "13198763535",
    note: "项目合作、技术问题、临时救火都可以直接打。",
  },
  {
    label: "邮箱",
    value: "hi@itcox.cn",
    note: "需要发需求、资料或交接说明，直接发邮件。",
    href: "mailto:hi@itcox.cn",
  },
  {
    label: "QQ",
    value: "57878778",
  },
];
---

<BaseLayout
  title="联系我"
  description="项目合作、技术支持和交付接手可直接联系。"
  sideBarActiveItemID="contact"
>
  <section class="max-w-4xl pb-12">
    <div class="text-sm uppercase tracking-[0.18em] opacity-60">Contact</div>
    <h1 class="mt-3 text-3xl font-bold leading-tight sm:text-4xl lg:text-6xl">有事直接联系。</h1>
    <p class="mt-4 max-w-3xl text-base leading-7 opacity-80 sm:text-lg sm:leading-8 lg:mt-5 lg:text-2xl lg:leading-[1.6]">
      有项目、问题或交接需求，直接联系。
    </p>
  </section>

  <section class="grid gap-4">
    {
      contactItems.map((item) => (
        <div class="rounded-lg border border-base-300 bg-base-100 p-6 shadow-sm lg:p-8">
          <div class="text-sm opacity-60">{item.label}</div>
          <div class="mt-3 break-all text-xl font-bold sm:text-2xl lg:text-4xl">{item.value}</div>
          {item.note && <p class="mt-3 leading-7 opacity-80">{item.note}</p>}
          <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <button class="btn w-full sm:w-auto" type="button" data-copy-value={item.value} data-copy-label={item.label}>
              复制{item.label}
            </button>
            {
              item.href && (
                <a class="btn btn-outline w-full sm:w-auto" href={item.href} target="_blank" rel="noopener noreferrer">
                  发邮件
                </a>
              )
            }
          </div>
        </div>
      ))
    }
  </section>

  <p class="mt-6 text-sm opacity-60" data-copy-feedback></p>

  <script is:inline>
    (() => {
      const feedback = document.querySelector("[data-copy-feedback]");
      const buttons = Array.from(document.querySelectorAll("[data-copy-value]"));

      if (!(feedback instanceof HTMLElement) || !buttons.length) {
        return;
      }

      const setFeedback = (message) => {
        feedback.textContent = message;
      };

      buttons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) {
          return;
        }

        button.addEventListener("click", async () => {
          const value = button.dataset.copyValue;
          const label = button.dataset.copyLabel;

          if (!value || !label) {
            return;
          }

          try {
            await navigator.clipboard.writeText(value);
            setFeedback(`${label}已复制`);
          } catch {
            setFeedback(`复制失败，请手动复制：${value}`);
          }
        });
      });
    })();
  </script>
</BaseLayout>
