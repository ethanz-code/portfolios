---
import BaseLayout from "../layouts/BaseLayout.astro";

const primaryContact = {
  label: "手机号",
  value: "13198763535",
  note: "优先电话。适合项目合作、技术问题、临时救火。",
  href: "tel:13198763535",
};

const secondaryContactItems = [
  {
    label: "邮箱",
    value: "hi@itcox.cn",
    note: "发需求、资料、交接说明。",
    href: "mailto:hi@itcox.cn",
    action: "发邮件",
  },
  {
    label: "QQ",
    value: "57878778",
    note: "适合补充沟通和文件传递。",
  },
];
---

<BaseLayout
  title="联系我"
  description="项目合作、技术支持和交付接手可直接联系。"
  sideBarActiveItemID="contact"
>
  <section class="max-w-4xl pb-10">
    <div class="text-sm uppercase tracking-[0.18em] opacity-60">Contact</div>
    <h1 class="mt-3 text-3xl font-bold leading-tight sm:text-4xl lg:text-6xl">直接联系。</h1>
    <p class="mt-4 max-w-3xl text-base leading-7 opacity-80 sm:text-lg sm:leading-8 lg:mt-5 lg:text-2xl lg:leading-[1.55]">
      项目合作、技术支持、交付接手，直接找我。
    </p>
  </section>

  <section class="max-w-4xl border-t border-base-300">
    <div class="py-6 sm:py-8" data-contact-row>
      <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
        <div class="max-w-2xl">
          <div class="text-sm opacity-60">{primaryContact.label}</div>
          <div class="mt-3 break-all text-3xl font-bold leading-tight sm:text-4xl lg:text-5xl">{primaryContact.value}</div>
          <p class="mt-3 max-w-xl leading-7 opacity-80 lg:text-lg lg:leading-8">{primaryContact.note}</p>
        </div>
        <div class="flex flex-col gap-3 sm:shrink-0 sm:flex-row sm:flex-wrap">
          <a class="btn w-full sm:w-auto" href={primaryContact.href}>拨打电话</a>
          <button
            class="btn btn-outline w-full sm:w-auto"
            type="button"
            data-copy-value={primaryContact.value}
            data-copy-label={primaryContact.label}
          >
            复制号码
          </button>
        </div>
      </div>
      <p class="mt-4 min-h-5 text-sm opacity-60" data-copy-feedback></p>
    </div>

    <div class="divide-y divide-base-300 border-t border-base-300">
      {
        secondaryContactItems.map((item) => (
          <div class="py-6 sm:py-8" data-contact-row>
            <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
              <div class="max-w-2xl">
                <div class="text-sm opacity-60">{item.label}</div>
                <div class="mt-3 break-all text-xl font-bold leading-tight sm:text-2xl lg:text-3xl">{item.value}</div>
                <p class="mt-3 leading-7 opacity-80">{item.note}</p>
              </div>
              <div class="flex flex-col gap-3 sm:shrink-0 sm:flex-row sm:flex-wrap">
                <button
                  class="btn w-full sm:w-auto"
                  type="button"
                  data-copy-value={item.value}
                  data-copy-label={item.label}
                >
                  复制{item.label}
                </button>
                {
                  item.href && (
                    <a class="btn btn-outline w-full sm:w-auto" href={item.href} target="_blank" rel="noopener noreferrer">
                      {item.action}
                    </a>
                  )
                }
              </div>
            </div>
            <p class="mt-4 min-h-5 text-sm opacity-60" data-copy-feedback></p>
          </div>
        ))
      }
    </div>
  </section>

  <script is:inline>
    (() => {
      const buttons = Array.from(document.querySelectorAll("[data-copy-value]"));

      if (!buttons.length) {
        return;
      }

      const setFeedback = (button, message) => {
        const row = button.closest("[data-contact-row]");
        const feedback = row?.querySelector("[data-copy-feedback]");

        if (!(feedback instanceof HTMLElement)) {
          return;
        }

        feedback.textContent = message;
      };

      buttons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) {
          return;
        }

        button.addEventListener("click", async () => {
          const value = button.dataset.copyValue;
          const label = button.dataset.copyLabel;

          if (!value || !label) {
            return;
          }

          try {
            await navigator.clipboard.writeText(value);
            setFeedback(button, `${label}已复制`);
          } catch {
            setFeedback(button, `复制失败，请手动复制：${value}`);
          }
        });
      });
    })();
  </script>
</BaseLayout>
