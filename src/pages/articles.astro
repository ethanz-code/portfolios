---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";
import "dayjs/locale/zh-cn";
import { getContentEntryPath } from "../lib/content-routes";

dayjs.extend(localizedFormat);
dayjs.locale("zh-cn");

const articles = (await getCollection("articles"))
  .filter((article) => !article.data.draft)
  .sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf());
---

<BaseLayout title="文章" description="张永鑫的文章、复盘和随手记录。" sideBarActiveItemID="articles">
  <h1 class="sr-only">文章</h1>

  <section class="grid w-full min-w-0 max-w-3xl gap-4">
    {
      articles.map((article) => (
        <a
          href={getContentEntryPath("articles", article)}
          class="block min-w-0 border-b border-base-300 py-5 transition hover:border-base-content"
        >
          <div class="mb-2 flex flex-wrap items-center gap-2">
            <time class="text-sm opacity-60">{dayjs(article.data.publishedDate).format("LL")}</time>
            {article.data.tags?.map((tag) => <span class="badge badge-ghost badge-sm">{tag}</span>)}
          </div>
          <h2 class="break-words text-lg font-bold leading-snug sm:text-xl">{article.data.title}</h2>
          <p class="mt-2 break-words leading-7 opacity-75">{article.data.description}</p>
        </a>
      ))
    }
  </section>
</BaseLayout>
