---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="项目" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">重点项目</div>
  </div>

  <HorizontalCard
    title="爱设计 AIGC"
    img="/post_img.webp"
    desc="从 0 到 1 独立上线 AIGC 聊天与绘画平台，覆盖认证、支付、流式对话、图片生成、作品广场、后台和多实例部署。"
    url="https://aigc.itcox.cn"
    badge="全栈"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="爱设计 AIGC 后台管理"
    img="/post_img.webp"
    desc="管理用户、充值、AI 聊天和图像生成，支撑运营、内容管理与数据查看。"
    url="https://admin-aigc.itcox.cn"
    badge="管理端"
  />

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">开源与内容</div>
  </div>

  <HorizontalCard
    title="小红书短视频解析服务"
    img="/post_img.webp"
    desc="面向开发者的短视频解析开源服务，聚焦内容提取、接口稳定和部署体验，GitHub 80+ stars。"
    url="https://github.com/ethanz-code/short-video-extractor"
    badge="开源"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="物联网竞赛知识库"
    img="/post_img.webp"
    desc="持续沉淀物联网竞赛笔记，服务 350+ 相关师生，累计浏览 10 万+。"
    url="https://www.yuque.com/newlandiot"
    badge="知识库"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="支付与资料获取系统"
    img="/post_img.webp"
    desc="为知识内容搭建资料分发和付费获取链路，验证内容产品的商业转化。"
    url="https://www.yuque.com/newlandiot"
    badge="运营"
  />
</BaseLayout>
