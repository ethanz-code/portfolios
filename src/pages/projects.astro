---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { resolveImageSource } from "../assets/images";

import { type CollectionEntry, getCollection } from "astro:content";

type ProjectEntry = CollectionEntry<"projects">;

const projects = await getCollection("projects");
const featuredProjects = projects
  .filter((project) => project.data.category === "featured")
  .sort((a, b) => a.data.order - b.data.order);
const contentProjects = projects
  .filter((project) => project.data.category === "content")
  .sort((a, b) => a.data.order - b.data.order);

const getProjectUrl = (project: ProjectEntry): string => {
  if (project.data.detailPage) {
    return `/projects/${project.slug}`;
  }

  if (project.data.externalUrl) {
    return project.data.externalUrl;
  }

  throw new Error(`Project "${project.slug}" is missing externalUrl while detailPage is false.`);
};

const getProjectImageLight = (project: ProjectEntry) =>
  resolveImageSource(
    project.data.coverImageLight
      ?? project.data.coverImage
      ?? project.data.heroImageLight
      ?? project.data.heroImage,
  );
const getProjectImageDark = (project: ProjectEntry) =>
  resolveImageSource(
    project.data.coverImageDark
      ?? project.data.coverImage
      ?? project.data.heroImageDark
      ?? project.data.heroImage,
  );
---

<BaseLayout
  title="项目"
  description="上线过、验证过、能说明交付方式的项目记录。"
  sideBarActiveItemID="projects"
>
  <section class="mb-10 max-w-3xl">
    <div class="mb-3 text-3xl font-bold sm:text-4xl lg:text-6xl">项目</div>
    <p class="text-base leading-7 opacity-80 sm:text-lg sm:leading-8">
      挑几件做过、上线过、还能继续维护的项目放在这里。
    </p>
  </section>

  <div>
    <div class="mb-5 w-full text-2xl font-bold sm:text-3xl">重点项目</div>
  </div>

  <div class="max-w-3xl">
    {
      featuredProjects.map((project, index) => (
        <>
          <HorizontalCard
            title={project.data.title}
            imgLight={getProjectImageLight(project)}
            imgDark={getProjectImageDark(project)}
            desc={project.data.description}
            url={getProjectUrl(project)}
            badge={project.data.badge}
            target={project.data.detailPage ? "_self" : "_blank"}
          />
          {index < featuredProjects.length - 1 && <div class="divider my-0" />}
        </>
      ))
    }
  </div>

  {
    contentProjects.length > 0 && (
      <>
        <div>
          <div class="mb-5 mt-10 w-full text-2xl font-bold sm:text-3xl">开源与内容</div>
        </div>

        <div class="max-w-3xl">
          {
            contentProjects.map((project, index) => (
              <>
                <HorizontalCard
                  title={project.data.title}
                  imgLight={getProjectImageLight(project)}
                  imgDark={getProjectImageDark(project)}
                  desc={project.data.description}
                  url={getProjectUrl(project)}
                  badge={project.data.badge}
                  target={project.data.detailPage ? "_self" : "_blank"}
                />
                {index < contentProjects.length - 1 && <div class="divider my-0" />}
              </>
            ))
          }
        </div>
      </>
    )
  }
</BaseLayout>
