---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getContentEntryPath } from "../lib/content-routes";
import aiDesignEffectDisplayImage from "../assets/projects/ai-design-aigc/effect-display.webp";
import sxeasyHomeImage from "../assets/projects/sxeasy/home.webp";
import sxeasyHomeDarkImage from "../assets/projects/sxeasy/home-dark.webp";

import { type CollectionEntry, getCollection } from "astro:content";

type ProjectEntry = CollectionEntry<"projects">;

const projects = await getCollection("projects");
const featuredProjects = projects
  .filter((project) => project.data.category === "featured")
  .sort((a, b) => a.data.order - b.data.order);
const contentProjects = projects
  .filter((project) => project.data.category === "content")
  .sort((a, b) => a.data.order - b.data.order);

const getProjectUrl = (project: ProjectEntry): string => {
  if (project.data.detailPage) {
    return getContentEntryPath("projects", project);
  }

  if (project.data.externalUrl) {
    return project.data.externalUrl;
  }

  throw new Error(`Project "${project.id}" is missing externalUrl while detailPage is false.`);
};

const getProjectImageLight = (project: ProjectEntry) =>
  project.id === "sxeasy"
    ? sxeasyHomeImage
    : project.id === "ai-design-aigc"
      ? aiDesignEffectDisplayImage
      : project.data.heroImageLight ?? project.data.heroImage;
const getProjectImageDark = (project: ProjectEntry) =>
  project.id === "sxeasy"
    ? sxeasyHomeDarkImage
    : project.id === "ai-design-aigc"
      ? aiDesignEffectDisplayImage
      : project.data.heroImageDark ?? project.data.heroImage;
---

<BaseLayout
  title="项目"
  description="上线过、验证过、能说明交付方式的项目记录。"
  sideBarActiveItemID="projects"
>
  <h1 class="sr-only">项目</h1>

  <h2 class="mb-5 w-full text-xl font-bold leading-tight sm:text-2xl lg:text-3xl">重点项目</h2>

  <div class="w-full min-w-0 max-w-3xl">
    {
      featuredProjects.map((project, index) => (
        <>
          <HorizontalCard
            title={project.data.title}
            imgLight={getProjectImageLight(project)}
            imgDark={getProjectImageDark(project)}
            desc={project.data.description}
            url={getProjectUrl(project)}
            target={project.data.detailPage ? "_self" : "_blank"}
          />
          {index < featuredProjects.length - 1 && <div class="divider my-0" />}
        </>
      ))
    }
  </div>

  {
    contentProjects.length > 0 && (
      <>
        <h2 class="mb-5 mt-10 w-full text-xl font-bold leading-tight sm:text-2xl lg:text-3xl">开源与内容</h2>

        <div class="w-full min-w-0 max-w-3xl">
          {
            contentProjects.map((project, index) => (
              <>
                <HorizontalCard
                  title={project.data.title}
                  imgLight={getProjectImageLight(project)}
                  imgDark={getProjectImageDark(project)}
                  desc={project.data.description}
                  url={getProjectUrl(project)}
                  target={project.data.detailPage ? "_self" : "_blank"}
                  compactMobile={true}
                />
                {index < contentProjects.length - 1 && <div class="divider my-0" />}
              </>
            ))
          }
        </div>
      </>
    )
  }
</BaseLayout>
