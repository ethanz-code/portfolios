      if (
        !fromGroup ||
        !toGroup ||
        fromShortcutIndex < 0 ||
        fromShortcutIndex >= fromGroup.shortcuts.length ||
        (fromGroupIndex === toGroupIndex && fromShortcutIndex === toShortcutIndex)
      ) {
        return false;
      }

      const [shortcut] = fromGroup.shortcuts.splice(fromShortcutIndex, 1);
      const adjustedTargetIndex =
        fromGroupIndex === toGroupIndex && fromShortcutIndex < toShortcutIndex
          ? toShortcutIndex - 1
          : toShortcutIndex;
      const boundedTargetIndex = Math.min(Math.max(adjustedTargetIndex, 0), toGroup.shortcuts.length);

      if (boundedTargetIndex === fromShortcutIndex && fromGroupIndex === toGroupIndex) {
        return false;
