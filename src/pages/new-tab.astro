          const itemLabelText = document.createElement("small");
          itemLabelText.className = "block min-w-0 overflow-hidden text-ellipsis whitespace-nowrap text-[0.68rem] font-semibold leading-tight text-base-content/50";
          itemLabelText.textContent = getShortcutSubtitle(shortcut);

          itemLabel.append(itemLabelTitle, itemLabelText);

          const tooltip = document.createElement("span");
          tooltip.className = "shortcut-item__tooltip pointer-events-none absolute bottom-[calc(100%+0.55rem)] left-1/2 z-40 grid min-w-36 max-w-56 -translate-x-1/2 translate-y-1.5 gap-[0.18rem] rounded-[0.45rem] border border-base-content/20 bg-base-100 px-2.5 py-2 text-base-content opacity-0 shadow-xl transition duration-150 after:absolute after:left-1/2 after:top-full after:h-2 after:w-2 after:-translate-x-1/2 after:-translate-y-1/2 after:rotate-45 after:border-b after:border-r after:border-base-content/20 after:bg-base-100 after:content-[''] group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:translate-y-0 group-focus-within:opacity-100 max-sm:hidden";
          tooltip.role = "tooltip";

          const tooltipTitle = document.createElement("strong");
          tooltipTitle.className = "block overflow-hidden text-ellipsis whitespace-nowrap";
          tooltipTitle.dataset.newTabColorTarget = "itemLabel";
          tooltipTitle.textContent = shortcut.title;

          const tooltipText = document.createElement("small");
          tooltipText.className = "block overflow-hidden text-ellipsis whitespace-nowrap text-xs leading-snug text-base-content/60";
          tooltipText.textContent = getShortcutSubtitle(shortcut);

          tooltip.append(tooltipTitle, tooltipText);
          item.append(icon, itemLabel);

          if (shortcutEditMode) {
            const itemMenuButton = document.createElement("button");
            itemMenuButton.className = "btn btn-square btn-ghost btn-xs shortcut-item__menu absolute -right-1 -top-1 z-20 h-[1.15rem] min-h-[1.15rem] w-[1.15rem] rounded-full border border-base-content/15 bg-base-100 p-0 text-base-content/70 opacity-80 transition hover:opacity-100 group-hover:opacity-100 group-focus-within:opacity-100 max-sm:h-7 max-sm:min-h-7 max-sm:w-7 max-sm:opacity-100 [&_svg]:h-3 [&_svg]:w-3";
            itemMenuButton.type = "button";
            itemMenuButton.title = "item 操作";
            itemMenuButton.setAttribute("aria-label", `item 操作：${shortcut.title}`);
            itemMenuButton.innerHTML = getIconMarkup("more");
            itemMenuButton.addEventListener("click", (event) => {
              openShortcutContextMenu({
                event,
                fallbackElement: itemMenuButton,
                title: shortcut.title,
                subtitle: getShortcutSubtitle(shortcut),
                actions: [
                  {
                    label: "修改 item",
                    icon: "edit",
                    onSelect: () => {
                      const form = createShortcutEditForm(group, shortcut);
                      itemShell.replaceWith(form);
                      focusFirstInput(form);
                    },
                  },
                  {
                    label: settingsLabels.removeShortcutLabel ?? "删除 item",
                    icon: "trash",
                    danger: true,
                    onSelect: () => {
                      const currentShortcutIndex = group.shortcuts.indexOf(shortcut);

                      if (currentShortcutIndex < 0) {
                        return;
                      }

                      group.shortcuts.splice(currentShortcutIndex, 1);
                      persistConfigChange("已删除");
                    },
                  },
                ],
              });
            });

            itemShell.append(itemMenuButton);
          }

          itemShell.append(item, tooltip);
          items.append(itemShell);
        });

        if (shortcutEditMode) {
          const addShortcutButton = document.createElement("button");
          addShortcutButton.className = "shortcut-item shortcut-item--add group/item relative grid h-11 w-11 place-items-center rounded-[0.45rem] border border-dashed border-base-content/10 bg-transparent p-0 font-[inherit] text-base-content/40 opacity-60 transition-[transform,border-color,background-color,opacity] duration-180 hover:-translate-y-0.5 hover:border-base-content/20 hover:bg-base-100/20 hover:opacity-80 focus-visible:-translate-y-0.5 focus-visible:border-base-content/20 focus-visible:bg-base-100/20 focus-visible:opacity-80 focus-visible:outline-none";
          addShortcutButton.type = "button";
          addShortcutButton.title = settingsLabels.addShortcutLabel ?? "添加 item";
          addShortcutButton.setAttribute("aria-label", `${settingsLabels.addShortcutLabel ?? "添加 item"}：${group.title}`);
          const addShortcutIcon = document.createElement("span");
          addShortcutIcon.className = "shortcut-item__icon relative grid h-[1.7rem] w-[1.7rem] place-items-center overflow-hidden";
          addShortcutIcon.setAttribute("aria-hidden", "true");
          addShortcutIcon.innerHTML = getIconMarkup("plus");

          const addShortcutTooltip = document.createElement("span");
          addShortcutTooltip.className = "shortcut-item__tooltip shortcut-item__tooltip--action pointer-events-none absolute bottom-[calc(100%+0.55rem)] left-1/2 grid min-w-36 max-w-56 -translate-x-1/2 translate-y-1.5 gap-[0.18rem] rounded-[0.45rem] border border-base-content/20 bg-base-100 px-2.5 py-2 text-base-content opacity-0 shadow-xl transition duration-150 after:absolute after:left-1/2 after:top-full after:h-2 after:w-2 after:-translate-x-1/2 after:-translate-y-1/2 after:rotate-45 after:border-b after:border-r after:border-base-content/20 after:bg-base-100 after:content-[''] group-hover/item:translate-y-0 group-hover/item:opacity-100 group-focus-visible/item:translate-y-0 group-focus-visible/item:opacity-100 max-sm:hidden";
          addShortcutTooltip.role = "tooltip";
          const addShortcutTooltipTitle = document.createElement("strong");
          addShortcutTooltipTitle.className = "block overflow-hidden text-ellipsis whitespace-nowrap";
          addShortcutTooltipTitle.textContent = settingsLabels.addShortcutLabel ?? "添加 item";
          const addShortcutTooltipText = document.createElement("small");
          addShortcutTooltipText.className = "block overflow-hidden text-ellipsis whitespace-nowrap text-xs leading-snug text-base-content/60";
          addShortcutTooltipText.textContent = `插入到 ${group.title}`;
          addShortcutTooltip.append(addShortcutTooltipTitle, addShortcutTooltipText);
          addShortcutButton.append(addShortcutIcon, addShortcutTooltip);
          addShortcutButton.addEventListener("click", () => {
            const form = createShortcutAddForm(group);
            addShortcutButton.replaceWith(form);
            focusFirstInput(form);
          });

          items.append(addShortcutButton);
        }

        section.append(summary, items);
        stack.append(section);
      });

      if (shortcutEditMode) {
        if (stack.dataset.groupDropBound !== "true") {
          stack.addEventListener("dragover", (event) => {
            const payload = readDragPayload(event);

            if (!shortcutEditMode || payload?.type !== "group") {
              return;
            }

            event.preventDefault();
            if (event.dataTransfer) {
              event.dataTransfer.dropEffect = "move";
            }
            clearDropIndicators(stack);
            setDropContainer(stack);
          });
          stack.addEventListener("dragleave", () => {
            clearDropElement(stack);
          });
          stack.addEventListener("drop", (event) => {
            const payload = readDragPayload(event);

            if (!shortcutEditMode || payload?.type !== "group") {
              return;
            }

            event.preventDefault();
            clearDropIndicators(stack);

            if (moveArrayItem(newTabState.shortcutGroups, Number(payload.groupIndex), newTabState.shortcutGroups.length)) {
              persistConfigChange("已排序");
            }
          });
          stack.dataset.groupDropBound = "true";
        }

        const addGroupButton = document.createElement("button");
        addGroupButton.className = "shortcut-group shortcut-group--add grid grid-cols-[minmax(5rem,7rem)_minmax(0,1fr)] items-center border-0 bg-transparent px-0 py-1 text-base-content/45 opacity-50 transition duration-180 hover:-translate-y-0.5 hover:text-base-content/65 hover:opacity-75 focus-visible:-translate-y-0.5 focus-visible:text-base-content/65 focus-visible:opacity-75 focus-visible:outline-none max-sm:grid-cols-1";
        addGroupButton.type = "button";
        addGroupButton.setAttribute("aria-label", settingsLabels.addGroupLabel ?? "添加分组");
        const addGroupSummary = document.createElement("span");
        addGroupSummary.className = "shortcut-group__summary flex w-full items-center justify-between gap-2 text-[0.88rem] font-bold";
        const addGroupTitle = document.createElement("span");
        addGroupTitle.textContent = settingsLabels.addGroupLabel ?? "添加分组";
        const addGroupMark = document.createElement("span");
        addGroupMark.className = "grid h-5 w-5 place-items-center [&_svg]:h-3.5 [&_svg]:w-3.5";
        addGroupMark.setAttribute("aria-hidden", "true");
        addGroupMark.innerHTML = getIconMarkup("plus");
        addGroupSummary.append(addGroupTitle, addGroupMark);

        addGroupButton.append(addGroupSummary);
        addGroupButton.addEventListener("click", () => {
          const form = createGroupAddForm();
          addGroupButton.replaceWith(form);
          focusFirstInput(form);
        });

        stack.append(addGroupButton);
      }
    };

    const setStatus = (message) => {
      const status = document.querySelector("[data-config-status]");

      if (status instanceof HTMLElement) {
        status.textContent = message;
      }
    };

    const syncSettingsControls = () => {
      const nameInput = document.querySelector("[data-config-name]");
      const homeLabelInput = document.querySelector("[data-config-home-label]");
      const homeHrefInput = document.querySelector("[data-config-home-href]");
      const shortcutOpenModeInput = document.querySelector("[data-config-shortcut-open-mode]");
      const backgroundInput = document.querySelector("[data-config-background]");
      const backgroundOpacityInput = document.querySelector("[data-config-background-opacity]");
      const backgroundOpacityValue = document.querySelector("[data-config-background-opacity-value]");
      const backgroundStatus = document.querySelector("[data-config-background-status]");
      const textColorModeInput = document.querySelector("[data-config-text-color-mode]");
      const navigationColorInput = document.querySelector("[data-config-navigation-color]");
      const itemLabelColorInput = document.querySelector("[data-config-item-label-color]");

      if (nameInput instanceof HTMLInputElement) {
        nameInput.value = newTabState.userName;
      }

      if (homeLabelInput instanceof HTMLInputElement) {
        homeLabelInput.value = newTabState.homeLink.label;
      }

      if (homeHrefInput instanceof HTMLInputElement) {
        homeHrefInput.value = newTabState.homeLink.href;
      }

      if (shortcutOpenModeInput instanceof HTMLSelectElement) {
        shortcutOpenModeInput.value = newTabState.shortcutOpenMode;
      }

      if (backgroundInput instanceof HTMLInputElement) {
        backgroundInput.value = newTabState.backgroundImage.startsWith("data:")
          ? ""
          : newTabState.backgroundImage;
      }

      if (backgroundOpacityInput instanceof HTMLInputElement) {
        backgroundOpacityInput.value = String(Math.round(newTabState.backgroundOpacity));
      }

      if (backgroundOpacityValue instanceof HTMLElement) {
        backgroundOpacityValue.textContent = `${Math.round(newTabState.backgroundOpacity)}%`;
      }

      const resolvedTextColors = getResolvedTextColors() ?? newTabState.textColors;

      if (textColorModeInput instanceof HTMLSelectElement) {
        textColorModeInput.value = newTabState.textColors.mode;
      }

      if (navigationColorInput instanceof HTMLInputElement) {
        navigationColorInput.value = resolvedTextColors.navigationColor;
        navigationColorInput.title = "修改后切换为自定义";
      }

      if (itemLabelColorInput instanceof HTMLInputElement) {
        itemLabelColorInput.value = resolvedTextColors.itemLabelColor;
        itemLabelColorInput.title = "修改后切换为自定义";
      }

      if (backgroundStatus instanceof HTMLElement) {
        backgroundStatus.textContent = newTabState.backgroundImage.startsWith("data:")
          ? (settingsLabels.backgroundUploadedLabel ?? "已上传本地背景")
          : newTabState.backgroundImage
            ? (settingsLabels.backgroundUrlStatusLabel ?? "使用背景 URL")
            : (settingsLabels.backgroundEmptyLabel ?? "未设置背景");
      }
    };

    const persistConfigChange = (message = "已保存") => {
      writeStoredState();
      renderGreeting();
      renderHomeLink();
      renderSearchEngines();
      renderShortcutGroups();
      applyBackground();
      applyTextColors();
      setStatus(message);
    };

    const scheduleTextColorSave = () => {
      window.clearTimeout(textColorSaveTimer);
      applyTextColors();
      textColorSaveTimer = window.setTimeout(() => {
        writeStoredState();
        setStatus("已保存");
      }, 500);
    };

    const applyBackground = () => {
      const backgroundBase = document.querySelector("[data-new-tab-background-base]");
      const backgroundLayer = document.querySelector("[data-new-tab-background-layer]");

      if (!(backgroundBase instanceof HTMLElement) || !(backgroundLayer instanceof HTMLElement)) {
        return;
      }

      if (!newTabState.backgroundImage) {
        backgroundBase.hidden = true;
        backgroundBase.classList.add("hidden");
        backgroundLayer.hidden = true;
        backgroundLayer.classList.add("hidden");
        backgroundLayer.style.removeProperty("background-image");
        backgroundLayer.style.opacity = "0";
        return;
      }

      const cssUrl = newTabState.backgroundImage
        .replace(/\\/g, "\\\\")
        .replace(/"/g, '\\"')
        .replace(/\n/g, "");

      backgroundLayer.hidden = false;
      backgroundBase.hidden = false;
      backgroundBase.classList.remove("hidden");
      backgroundLayer.classList.remove("hidden");
      backgroundLayer.style.backgroundImage = `url("${cssUrl}")`;
      backgroundLayer.style.opacity = String(newTabState.backgroundOpacity / 100);
    };

    const getResolvedTextColors = () => {
      const presets = {
        light: {
          navigationColor: "#f8fafc",
          itemLabelColor: "#f8fafc",
        },
        dark: {
          navigationColor: "#111827",
          itemLabelColor: "#111827",
        },
      };

      if (newTabState.textColors.mode === "default") {
        return null;
      }

      if (newTabState.textColors.mode === "custom") {
        return newTabState.textColors;
      }

      return presets[newTabState.textColors.mode] ?? null;
    };

    const applyTextColors = () => {
      const colors = getResolvedTextColors();
      const colorTargets = document.querySelectorAll("[data-new-tab-color-target]");

      if (!colors) {
        delete document.documentElement.dataset.newTabTextColors;
        colorTargets.forEach((target) => {
          if (target instanceof HTMLElement) {
            target.style.removeProperty("color");
          }
        });
        return;
      }

      document.documentElement.dataset.newTabTextColors = newTabState.textColors.mode;
      colorTargets.forEach((target) => {
        if (!(target instanceof HTMLElement)) {
          return;
        }

        target.style.color = target.dataset.newTabColorTarget === "navigation"
          ? colors.navigationColor
          : colors.itemLabelColor;
      });
    };

    const renderAll = () => {
      renderSearchEngines();
      renderGreeting();
      renderHomeLink();
      renderShortcutGroups();
      applyBackground();
      applyTextColors();
      syncSettingsControls();
    };

    const downloadConfig = () => {
      const blob = new Blob([JSON.stringify(newTabState, null, 2)], {
        type: "application/json;charset=utf-8",
      });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");

      link.href = url;
      link.download = "new-tab-config.json";
      document.body.append(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
      setStatus("已导出");
    };

    const importConfigFromText = (text) => {
      newTabState = normalizeNewTabState(JSON.parse(text));
      writeStoredState();
      renderAll();
      setStatus("已导入");
    };

    const bindSearch = () => {
      const form = document.querySelector("[data-new-tab-search]");
      const input = document.querySelector("[data-search-query]");
      const select = document.querySelector("[data-search-engine]");

      if (
        !(form instanceof HTMLFormElement) ||
        !(input instanceof HTMLInputElement) ||
        !(select instanceof HTMLSelectElement) ||
        form.dataset.searchBound === "true"
      ) {
        return;
      }

      select.addEventListener("change", () => {
        newTabState.defaultSearchEngineId = select.value;
        writeStoredState();
        syncSettingsControls();
      });

      form.addEventListener("submit", (event) => {
        event.preventDefault();

        const query = input.value.trim();
        const selectedOption = select.selectedOptions[0];
        const searchUrl = selectedOption?.dataset.searchUrl;

        if (!query) {
          input.focus();
          return;
        }

        if (!searchUrl) {
          return;
        }

        window.location.assign(searchUrl.replace("{query}", encodeURIComponent(query)));
      });

      form.dataset.searchBound = "true";
    };

    const bindShortcutEditor = () => {
      const toggle = document.querySelector("[data-shortcut-edit-toggle]");

      if (!(toggle instanceof HTMLButtonElement) || toggle.dataset.shortcutEditBound === "true") {
        return;
      }

      toggle.addEventListener("click", () => {
        shortcutEditMode = !shortcutEditMode;
        renderShortcutGroups();
      });

      toggle.dataset.shortcutEditBound = "true";
      syncShortcutEditToggle();
    };

    const bindSettings = () => {
      const settings = document.querySelector("[data-config-drawer]");
      const openButton = document.querySelector("[data-config-open]");

      if (!(settings instanceof HTMLElement) || settings.dataset.settingsBound === "true") {
        return;
      }

      const nameInput = settings.querySelector("[data-config-name]");
      const homeLabelInput = settings.querySelector("[data-config-home-label]");
      const homeHrefInput = settings.querySelector("[data-config-home-href]");
      const shortcutOpenModeInput = settings.querySelector("[data-config-shortcut-open-mode]");
      const backgroundInput = settings.querySelector("[data-config-background]");
      const backgroundOpacityInput = settings.querySelector("[data-config-background-opacity]");
      const textColorModeInput = settings.querySelector("[data-config-text-color-mode]");
      const navigationColorInput = settings.querySelector("[data-config-navigation-color]");
      const itemLabelColorInput = settings.querySelector("[data-config-item-label-color]");
      const backgroundFileInput = settings.querySelector("[data-config-background-file]");
      const backgroundFileTrigger = settings.querySelector("[data-config-background-file-trigger]");
      const fileInput = settings.querySelector("[data-config-file]");
      const importButton = settings.querySelector("[data-config-import]");
      const exportButton = settings.querySelector("[data-config-export]");
      const clearBackgroundButton = settings.querySelector("[data-config-clear-background]");
      const resetButton = settings.querySelector("[data-config-reset]");
      const settingsBackdrop = settings.querySelector(".new-tab-config__backdrop");
      const settingsSheet = settings.querySelector(".new-tab-config__sheet");

      const openSettings = () => {
        settings.hidden = false;
        settings.classList.remove("hidden");
        window.requestAnimationFrame(() => {
          settings.dataset.open = "true";
          settings.classList.remove("pointer-events-none", "opacity-0");
          settings.classList.add("pointer-events-auto", "opacity-100");
          settingsBackdrop?.classList.remove("opacity-0");
          settingsBackdrop?.classList.add("opacity-100");
          settingsSheet?.classList.remove("translate-x-full");
          settingsSheet?.classList.add("translate-x-0");
        });
      };

      const closeSettings = () => {
        delete settings.dataset.open;
        settings.classList.remove("pointer-events-auto", "opacity-100");
        settings.classList.add("pointer-events-none", "opacity-0");
        settingsBackdrop?.classList.remove("opacity-100");
        settingsBackdrop?.classList.add("opacity-0");
        settingsSheet?.classList.remove("translate-x-0");
        settingsSheet?.classList.add("translate-x-full");
        window.setTimeout(() => {
          if (!settings.dataset.open) {
            settings.hidden = true;
            settings.classList.add("hidden");
          }
        }, 180);
      };

      openButton?.addEventListener("click", openSettings);
      settings.querySelectorAll("[data-config-close]").forEach((button) => {
        button.addEventListener("click", closeSettings);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && settings.dataset.open === "true") {
          closeSettings();
        }
      });

      nameInput?.addEventListener("input", () => {
        if (!(nameInput instanceof HTMLInputElement)) {
          return;
        }

        newTabState.userName = normalizeText(nameInput.value, defaultPayload.config?.userName ?? "Ethanz888");
        persistConfigChange();
      });

      homeLabelInput?.addEventListener("input", () => {
        if (!(homeLabelInput instanceof HTMLInputElement)) {
          return;
        }

        newTabState.homeLink.label = normalizeText(homeLabelInput.value, defaultPayload.config?.homeLink?.label ?? "资料卡首页");
        persistConfigChange();
      });

      homeHrefInput?.addEventListener("input", () => {
        if (!(homeHrefInput instanceof HTMLInputElement)) {
          return;
        }

        newTabState.homeLink.href = normalizeText(homeHrefInput.value, defaultPayload.config?.homeLink?.href ?? "/");
        persistConfigChange();
      });

      shortcutOpenModeInput?.addEventListener("change", () => {
        if (!(shortcutOpenModeInput instanceof HTMLSelectElement)) {
          return;
        }

        newTabState.shortcutOpenMode = normalizeShortcutOpenMode(shortcutOpenModeInput.value);
        persistConfigChange();
        syncSettingsControls();
      });

      backgroundInput?.addEventListener("input", () => {
        if (!(backgroundInput instanceof HTMLInputElement)) {
          return;
        }

        newTabState.backgroundImage = backgroundInput.value.trim();
        persistConfigChange();
      });

      backgroundOpacityInput?.addEventListener("input", () => {
        if (!(backgroundOpacityInput instanceof HTMLInputElement)) {
          return;
        }

        newTabState.backgroundOpacity = Math.min(100, Math.max(0, Number(backgroundOpacityInput.value)));
        persistConfigChange();
        syncSettingsControls();
      });

      const handleTextColorModeChange = () => {
        if (!(textColorModeInput instanceof HTMLSelectElement)) {
          return;
        }

        newTabState.textColors.mode = ["default", "light", "dark", "custom"].includes(textColorModeInput.value)
          ? textColorModeInput.value
          : "default";
        persistConfigChange();
        syncSettingsControls();
      };

      textColorModeInput?.addEventListener("input", handleTextColorModeChange);
      textColorModeInput?.addEventListener("change", handleTextColorModeChange);

      navigationColorInput?.addEventListener("input", () => {
        if (!(navigationColorInput instanceof HTMLInputElement)) {
          return;
        }

        newTabState.textColors.mode = "custom";
        newTabState.textColors.navigationColor = normalizeColor(
          navigationColorInput.value,
          defaultTextColors.navigationColor,
        );
        if (textColorModeInput instanceof HTMLSelectElement) {
          textColorModeInput.value = "custom";
        }
        scheduleTextColorSave();
      });

      itemLabelColorInput?.addEventListener("input", () => {
        if (!(itemLabelColorInput instanceof HTMLInputElement)) {
          return;
        }

        newTabState.textColors.mode = "custom";
        newTabState.textColors.itemLabelColor = normalizeColor(
          itemLabelColorInput.value,
          defaultTextColors.itemLabelColor,
        );
        if (textColorModeInput instanceof HTMLSelectElement) {
          textColorModeInput.value = "custom";
        }
        scheduleTextColorSave();
      });

      backgroundFileTrigger?.addEventListener("click", () => {
        if (backgroundFileInput instanceof HTMLInputElement) {
          backgroundFileInput.click();
        }
      });

      backgroundFileInput?.addEventListener("change", () => {
        if (!(backgroundFileInput instanceof HTMLInputElement)) {
          return;
        }

        const file = backgroundFileInput.files?.[0];

        if (!file) {
          return;
        }

        const reader = new FileReader();
        reader.addEventListener("load", () => {
          if (typeof reader.result !== "string") {
            return;
          }

          newTabState.backgroundImage = reader.result;
          writeStoredState();
          renderAll();
          backgroundFileInput.value = "";
          setStatus("背景已保存");
        });
        reader.readAsDataURL(file);
      });

      importButton?.addEventListener("click", () => {
        if (fileInput instanceof HTMLInputElement) {
          fileInput.click();
        }
      });

      fileInput?.addEventListener("change", () => {
        if (!(fileInput instanceof HTMLInputElement)) {
          return;
        }

        const file = fileInput.files?.[0];

        if (!file) {
          return;
        }

        const reader = new FileReader();
        reader.addEventListener("load", () => {
          if (typeof reader.result !== "string") {
            return;
          }

          try {
            importConfigFromText(reader.result);
          } catch {
            setStatus("JSON 格式不对");
          }

          fileInput.value = "";
        });
        reader.readAsText(file);
      });

      exportButton?.addEventListener("click", downloadConfig);

      clearBackgroundButton?.addEventListener("click", () => {
        newTabState.backgroundImage = "";
        writeStoredState();
        renderAll();
        setStatus("背景已清除");
      });

      resetButton?.addEventListener("click", () => {
        newTabState = defaultState();

        try {
          window.localStorage.removeItem(storageKey);
        } catch {
          // Ignore storage write failures and keep the reset state in memory.
        }

        renderAll();
        setStatus("已恢复默认");
      });
      settings.dataset.settingsBound = "true";
    };

    const bindNewTab = () => {
      newTabState = readStoredState();
      shortcutLogoCache = readShortcutLogoCache();
      renderAll();
      bindSearch();
      bindShortcutEditor();
      bindSettings();
      bindShortcutContextMenuDismissal();
    };

    const clearNewTabBackground = () => {
      const backgroundBase = document.querySelector("[data-new-tab-background-base]");
      const backgroundLayer = document.querySelector("[data-new-tab-background-layer]");

      delete document.documentElement.dataset.newTabBackground;
      delete document.documentElement.dataset.newTabTextColors;
      closeShortcutContextMenu();

      if (backgroundBase instanceof HTMLElement) {
        backgroundBase.hidden = true;
        backgroundBase.classList.add("hidden");
      }

      if (backgroundLayer instanceof HTMLElement) {
        backgroundLayer.hidden = true;
        backgroundLayer.classList.add("hidden");
        backgroundLayer.style.removeProperty("background-image");
        backgroundLayer.style.opacity = "0";
      }
    };

    bindNewTab();
    document.addEventListener("astro:after-swap", bindNewTab);
    document.addEventListener("astro:before-swap", clearNewTabBackground);
  </script>

</BaseLayout>
