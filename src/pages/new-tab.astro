      if (shortcut.logo) {
        const logoUrl = resolveShortcutAssetUrl(shortcut.logo, shortcut.url);

        return isRemoteUrl(logoUrl)
          ? [getProxyUrl(logoUrl), logoUrl]
          : [logoUrl];
      }

      let originUrl = "";
      try {
        originUrl = new URL(shortcut.url).origin;
      } catch {
        originUrl = "";
      }

      const hostname = getShortcutHostname(shortcut.url);
      const candidates = [];
      const cachedLogo = getCachedShortcutLogo(shortcut);
      const canUseCachedLogo = cachedLogo?.resolverVersion === logoResolverVersion;

      if (canUseCachedLogo && cachedLogo?.logoUrl) {
        pushLogoCandidate(candidates, cachedLogo.logoUrl, false);
      }

      if (canUseCachedLogo && Array.isArray(cachedLogo?.candidates)) {
        pushLogoCandidates(candidates, cachedLogo.candidates);
      }

      const commonPaths = [
        "/favicon.svg",
        "/favicon.png",
        "/favicon.ico",
        "/logo.svg",
        "/logo.png",
        "/icon.svg",
        "/icon.png",
        "/apple-touch-icon.png",
        "/apple-touch-icon-precomposed.png",
        "/assets/logo.svg",
        "/assets/logo.png",
        "/assets/favicon.svg",
        "/assets/favicon.png",
        "/images/logo.svg",
        "/images/logo.png",
        "/images/logo-blue.png",
        "/images/logo-light.png",
      ];

      commonPaths.forEach((path) => {
        if (!originUrl) {
          return;
        }

        pushLogoCandidate(candidates, new URL(path, originUrl).href);
      });

      const duckDuckGoFavicon = `https://icons.duckduckgo.com/ip3/${hostname}.ico`;
      const googleFavicon = `https://www.google.com/s2/favicons?domain=${encodeURIComponent(hostname)}&sz=64`;
      const directFavicon = `https://${hostname}/favicon.ico`;

      pushLogoCandidate(candidates, duckDuckGoFavicon);
      pushLogoCandidate(candidates, googleFavicon);
      pushLogoCandidate(candidates, directFavicon, false);

      return candidates;
    };

    const getShortcutSubtitle = (shortcut) =>
      shortcut.description ?? getCachedShortcutLogo(shortcut)?.description ?? getShortcutHostname(shortcut.url);

    const collectLogoUrlsFromHtml = (html, baseUrl) => {
      const candidates = [];
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, "text/html");
      const pageTitle = normalizeText(
        doc.querySelector('meta[property="og:site_name"]')?.getAttribute("content") ??
        doc.querySelector("title")?.textContent,
      );
      const iconSelector = [
        'link[rel~="icon"][href]',
        'link[rel~="apple-touch-icon"][href]',
        'link[rel~="apple-touch-icon-precomposed"][href]',
        'link[rel~="mask-icon"][href]',
        'meta[property="og:logo"][content]',
        'meta[property="og:image"][content]',
        'meta[name="twitter:image"][content]',
      ].join(",");

      doc.querySelectorAll(iconSelector).forEach((element) => {
        const rawUrl = element.getAttribute("href") ?? element.getAttribute("content");
        const logoUrl = resolveShortcutAssetUrl(rawUrl, baseUrl);

        if (logoUrl && !candidates.includes(logoUrl)) {
          candidates.push(logoUrl);
        }
      });

      doc.querySelectorAll('script[type="application/ld+json"]').forEach((script) => {
        try {
          const data = JSON.parse(script.textContent ?? "null");
          const nodes = Array.isArray(data) ? data : [data];

          nodes.forEach((node) => {
            const logo = node?.logo?.url ?? node?.logo;
            const logoUrl = typeof logo === "string" ? resolveShortcutAssetUrl(logo, baseUrl) : "";

            if (logoUrl && !candidates.includes(logoUrl)) {
              candidates.push(logoUrl);
            }
          });
        } catch {
          // Ignore invalid structured data and keep other logo sources.
        }
      });

      return {
        candidates,
        title: /^loading\.{0,3}$/i.test(pageTitle) ? "" : pageTitle,
        description: normalizeText(
          doc.querySelector('meta[name="description"]')?.getAttribute("content") ??
          doc.querySelector('meta[property="og:description"]')?.getAttribute("content"),
        ),
      };
    };

    const collectAssetScriptUrlsFromHtml = (html, baseUrl) => {
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, "text/html");
      const urls = [];
      const selector = [
        "script[src]",
        'link[rel="modulepreload"][href]',
        'link[rel="preload"][as="script"][href]',
      ].join(",");

      doc.querySelectorAll(selector).forEach((element) => {
        const rawUrl = element.getAttribute("src") ?? element.getAttribute("href");
        const scriptUrl = resolveShortcutAssetUrl(rawUrl, baseUrl);

        if (scriptUrl && !urls.includes(scriptUrl)) {
          urls.push(scriptUrl);
        }
      });

      return urls;
    };

    const collectBundledLogoUrls = async (html, baseUrl, signal) => {
      const scriptUrls = collectAssetScriptUrlsFromHtml(html, baseUrl).slice(0, 2);
      const candidates = [];

      for (const scriptUrl of scriptUrls) {
        try {
          const response = await fetch(getProxyUrl(scriptUrl), { signal });
          const script = response.ok ? await response.text() : "";

          if (/assets\/js\/1panel-(?:menu-)?logo-[\w-]+\.js/.test(script)) {
            candidates.push(onePanelLogoDataUrl);
          }
        } catch {
          // Ignore optional bundle probing and keep the regular favicon chain.
        }
      }

      return {
        logoUrl: candidates[0],
        candidates: candidates.filter((url, index, items) => items.indexOf(url) === index),
      };
    };

    const hasUsefulCachedLogoMetadata = (cached) =>
      Boolean(
        cached?.resolverVersion === logoResolverVersion &&
        (
          cached.metadataResolved ||
          (Array.isArray(cached.candidates) && cached.candidates.length) ||
          cached.description ||
          cached.failedAt
        ),
      );

    const mergeShortcutLogoCache = (cacheKey, payload) => {
      if (!cacheKey) {
        return;
      }

      const existing = shortcutLogoCache[cacheKey] ?? {};
      const candidates = [
        ...(Array.isArray(existing.candidates) ? existing.candidates : []),
        ...(Array.isArray(payload.candidates) ? payload.candidates : []),
      ].filter((url, index, items) => url && items.indexOf(url) === index);

      shortcutLogoCache = {
        ...shortcutLogoCache,
        [cacheKey]: {
          ...existing,
          ...payload,
          candidates,
          resolverVersion: logoResolverVersion,
          updatedAt: Date.now(),
        },
      };
      writeShortcutLogoCache();
    };

    const fetchShortcutMetadata = (shortcut) => {
      const cacheKey = getShortcutLogoCacheKey(shortcut.url);
      const cached = shortcutLogoCache[cacheKey];
      const cachedAt = Number(cached?.updatedAt ?? cached?.failedAt ?? 0);
      const isFresh = cachedAt && Date.now() - cachedAt < 7 * 24 * 60 * 60 * 1000;

      if (!isRemoteUrl(shortcut.url) || !canProxyUrl(shortcut.url)) {
        return Promise.resolve(cached);
      }

      if (isFresh && hasUsefulCachedLogoMetadata(cached)) {
        return Promise.resolve(cached);
      }

      if (shortcutLogoRequests.has(cacheKey)) {
        return shortcutLogoRequests.get(cacheKey);
      }

      const controller = new AbortController();
      const timeout = window.setTimeout(() => controller.abort(), 5000);
      const request = fetch(getProxyUrl(shortcut.url), {
        signal: controller.signal,
      })
        .then((response) => (response.ok ? response.text() : ""))
        .then(async (html) => {
          if (!html) {
            mergeShortcutLogoCache(cacheKey, {
              candidates: [],
              failedAt: Date.now(),
            });
            return shortcutLogoCache[cacheKey];
          }

          const discovered = collectLogoUrlsFromHtml(html, shortcut.url);
          const bundled = discovered.candidates.length
            ? { candidates: [] }
            : await collectBundledLogoUrls(html, shortcut.url, controller.signal);
          if (bundled.logoUrl) {
            discovered.logoUrl = bundled.logoUrl;
          }
          discovered.candidates = [
            ...discovered.candidates,
            ...bundled.candidates,
          ].filter((url, index, items) => url && items.indexOf(url) === index);
          discovered.logoUrl = discovered.logoUrl ?? discovered.candidates[0] ?? "";

          if (!discovered.candidates.length && !discovered.title && !discovered.description) {
            mergeShortcutLogoCache(cacheKey, {
              candidates: [],
              failedAt: Date.now(),
            });
            return shortcutLogoCache[cacheKey];
          }

          mergeShortcutLogoCache(cacheKey, {
            ...discovered,
            metadataResolved: true,
          });
          return shortcutLogoCache[cacheKey];
        })
        .catch(() => {
          mergeShortcutLogoCache(cacheKey, {
            candidates: [],
            failedAt: Date.now(),
          });
          return shortcutLogoCache[cacheKey];
        })
        .finally(() => {
          window.clearTimeout(timeout);
          shortcutLogoRequests.delete(cacheKey);
        });

      shortcutLogoRequests.set(cacheKey, request);
      return request;
    };

    const refreshShortcutMetadataDisplay = (shortcut, image) => {
      const item = image.closest(".shortcut-item");
      const itemShell = image.closest(".shortcut-item-shell");

      if (!(item instanceof HTMLElement)) {
        return;
      }

      const subtitle = getShortcutSubtitle(shortcut);
      const itemLabelText = item.querySelector(".shortcut-item__label small");
      const tooltipText = itemShell?.querySelector(".shortcut-item__tooltip small");

      item.setAttribute("aria-label", `${shortcut.title}：${subtitle}`);

      if (itemLabelText instanceof HTMLElement) {
        itemLabelText.textContent = subtitle;
      }

      if (tooltipText instanceof HTMLElement) {
        tooltipText.textContent = subtitle;
      }
    };

    const discoverShortcutLogo = (shortcut, image) => {
      if (shortcut.logo || !isRemoteUrl(shortcut.url)) {
        return;
      }

      fetchShortcutMetadata(shortcut).then((metadata) => {
        refreshShortcutMetadataDisplay(shortcut, image);

        if (!image.isConnected) {
          return;
        }

        const nextUrls = getShortcutLogoUrls(shortcut);
        const nextLogoUrl = nextUrls[0] ?? "";
        const shouldReplaceLoadedLogo = Boolean(
          metadata?.logoUrl &&
          nextLogoUrl &&
          image.src !== nextLogoUrl &&
          image.currentSrc !== nextLogoUrl,
        );

        if (!shouldReplaceLoadedLogo && image.complete && image.naturalWidth > 0) {
          return;
        }

        image.hidden = false;
        image.closest(".shortcut-item__icon")?.querySelector(".shortcut-item__initial")?.classList.add("hidden");
        image.dataset.logoFallbacks = JSON.stringify(nextUrls.slice(1));
        image.src = nextLogoUrl;
      });
    };

    const getNextLogoFallback = (image) => {
      const fallbacks = image.dataset.logoFallbacks
        ? JSON.parse(image.dataset.logoFallbacks)
        : [];
      const nextFallback = fallbacks.shift() ?? "";
      image.dataset.logoFallbacks = JSON.stringify(fallbacks);
      return nextFallback;
    };

    const bindLogoFallback = (image) => {
      image.addEventListener("load", () => {
        if (image.currentSrc && image.naturalWidth > 0) {
          const existing = shortcutLogoCache[image.dataset.logoCacheKey];

          if (
            existing?.metadataResolved &&
            existing?.logoUrl &&
            existing.logoUrl !== image.currentSrc
          ) {
            return;
          }

          mergeShortcutLogoCache(image.dataset.logoCacheKey, {
            logoUrl: image.currentSrc,
          });
        }
      });

      image.addEventListener("error", () => {
        const fallback = getNextLogoFallback(image);

        if (fallback && image.src !== fallback) {
          image.src = fallback;
          return;
        }

        image.hidden = true;
        image.closest(".shortcut-item__icon")?.querySelector(".shortcut-item__initial")?.classList.remove("hidden");
      });
    };

    const syncShortcutEditToggle = () => {
      const toggle = document.querySelector("[data-shortcut-edit-toggle]");

      if (!(toggle instanceof HTMLButtonElement)) {
        return;
      }

      toggle.setAttribute("aria-pressed", String(shortcutEditMode));
      toggle.title = shortcutEditMode ? "完成" : "编辑";
      toggle.setAttribute("aria-label", shortcutEditMode ? "完成编辑" : "编辑快捷方式");
      toggle.innerHTML = getIconMarkup(shortcutEditMode ? "check" : "edit");
    };

    const renderSearchEngines = () => {
      const select = document.querySelector("[data-search-engine]");

      if (!(select instanceof HTMLSelectElement)) {
        return;
      }

      select.textContent = "";
      newTabState.searchEngines.forEach((engine) => {
        const option = document.createElement("option");
        option.value = engine.id;
        option.dataset.searchUrl = engine.searchUrl;
        option.textContent = engine.label;
        select.append(option);
      });

      select.value = newTabState.defaultSearchEngineId;
    };

    const renderGreeting = () => {
      const greeting = document.querySelector("[data-new-tab-greeting]");

      if (!(greeting instanceof HTMLElement)) {
        return;
      }

      const hour = new Date().getHours();
      const greetingConfig = newTabState.greetings.find((item) => {
        if (item.from < item.to) {
          return hour >= item.from && hour < item.to;
        }

        return hour >= item.from || hour < item.to;
      });

      greeting.textContent = `${greetingConfig?.label ?? "你好"}，${newTabState.userName}`;
    };

    const renderHomeLink = () => {
      const homeLink = document.querySelector("[data-home-link]");

      if (!(homeLink instanceof HTMLAnchorElement)) {
        return;
      }

      homeLink.href = newTabState.homeLink.href;
      homeLink.textContent = newTabState.homeLink.label;
    };

    const renderShortcutGroups = () => {
      const stack = document.querySelector("[data-shortcut-stack]");

      if (!(stack instanceof HTMLElement)) {
        return;
      }

      stack.textContent = "";
      stack.dataset.editing = String(shortcutEditMode);
      closeShortcutContextMenu();
      syncShortcutEditToggle();

      newTabState.shortcutGroups.forEach((group, groupIndex) => {
        const section = document.createElement("section");
        section.className = shortcutEditMode
          ? "shortcut-group relative grid grid-cols-[minmax(7.5rem,8.5rem)_minmax(0,1fr)] items-start gap-4 py-2 max-sm:grid-cols-1 max-sm:gap-3"
          : "shortcut-group relative grid grid-cols-[minmax(5rem,7rem)_minmax(0,1fr)] items-start gap-4 py-2 max-sm:grid-cols-1 max-sm:gap-3";
        section.setAttribute("aria-label", `${group.title}快捷方式`);

        const summary = document.createElement("div");
        summary.className = shortcutEditMode
          ? "shortcut-group__summary grid justify-start gap-1 text-[0.88rem] font-bold text-base-content/65"
          : "shortcut-group__summary flex items-center justify-between gap-2 text-[0.88rem] font-bold text-base-content/65 max-sm:justify-between";

        const title = document.createElement("span");
        title.className = shortcutEditMode
          ? "min-w-0 whitespace-nowrap text-inherit"
          : "min-w-0 text-inherit";
        title.dataset.newTabColorTarget = "itemLabel";
        title.textContent = group.title;

        const titleWrap = document.createElement("span");
        titleWrap.className = "flex min-w-0 items-center gap-2";

        if (shortcutEditMode) {
          const openGroupEditForm = () => {
            const form = createGroupEditForm(group);
            section.replaceWith(form);
            focusFirstInput(form);
          };
          const removeGroup = () => {
            const currentGroupIndex = newTabState.shortcutGroups.indexOf(group);

            if (currentGroupIndex < 0) {
              return;
            }

            newTabState.shortcutGroups.splice(currentGroupIndex, 1);
            persistConfigChange("已删除");
          };
          const openGroupMenu = (event) => {
            openShortcutContextMenu({
              event,
              fallbackElement: section,
              title: group.title,
              subtitle: "分组操作",
              actions: [
                {
                  label: "修改分组",
                  icon: "edit",
                  onSelect: openGroupEditForm,
                },
                {
                  label: settingsLabels.removeGroupLabel ?? "删除分组",
                  icon: "trash",
                  danger: true,
                  onSelect: removeGroup,
                },
              ],
            });
          };

          const groupDragHandle = document.createElement("span");
          groupDragHandle.className = "shortcut-drag-handle grid h-5 w-4 shrink-0 cursor-grab place-items-center rounded border border-base-content/10 bg-base-100/80 text-base-content/35 transition hover:text-base-content/70 active:cursor-grabbing";
          groupDragHandle.draggable = true;
          groupDragHandle.title = "拖拽排序";
          groupDragHandle.setAttribute("aria-label", `拖拽排序：${group.title}`);
          groupDragHandle.innerHTML = dragHandleIcon;
          groupDragHandle.addEventListener("dragstart", (event) => {
            setDragPayload({
              type: "group",
              groupIndex,
            });
            if (event.dataTransfer) {
              event.dataTransfer.setData("application/json", JSON.stringify(activeDragPayload));
              event.dataTransfer.setData("text/plain", group.title);
              event.dataTransfer.effectAllowed = "move";
            }
            section.classList.add("opacity-50");
          });
          groupDragHandle.addEventListener("dragend", () => {
            section.classList.remove("opacity-50");
            clearDropIndicators(stack);
            clearDragPayload();
          });
          titleWrap.append(groupDragHandle);
          titleWrap.addEventListener("contextmenu", openGroupMenu);
        }

        titleWrap.append(title);

        const count = document.createElement("span");
        count.className = "text-xs font-semibold text-base-content/40";
        count.textContent = String(group.shortcuts.length);

        const actions = document.createElement("span");
        actions.className = "shortcut-group__actions inline-flex items-center gap-1.5";
        actions.append(count);

        if (shortcutEditMode) {
          const groupMenuButton = document.createElement("button");
          groupMenuButton.className = "btn btn-square btn-ghost btn-xs shortcut-group__menu h-6 min-h-6 w-6 p-0 text-base-content/55 opacity-65 transition hover:text-base-content/80 hover:opacity-100 focus-visible:text-base-content/80 [&_svg]:h-3.5 [&_svg]:w-3.5";
          groupMenuButton.type = "button";
          groupMenuButton.title = "分组操作";
          groupMenuButton.setAttribute("aria-label", `分组操作：${group.title}`);
          groupMenuButton.innerHTML = getIconMarkup("more");
          groupMenuButton.addEventListener("click", (event) => {
            openShortcutContextMenu({
              event,
              fallbackElement: groupMenuButton,
              title: group.title,
              subtitle: "分组操作",
              actions: [
                {
                  label: "修改分组",
                  icon: "edit",
                  onSelect: () => {
                    const form = createGroupEditForm(group);
                    section.replaceWith(form);
                    focusFirstInput(form);
                  },
                },
                {
                  label: settingsLabels.removeGroupLabel ?? "删除分组",
                  icon: "trash",
                  danger: true,
                  onSelect: () => {
                    const currentGroupIndex = newTabState.shortcutGroups.indexOf(group);

                    if (currentGroupIndex < 0) {
                      return;
                    }

                    newTabState.shortcutGroups.splice(currentGroupIndex, 1);
                    persistConfigChange("已删除");
                  },
                },
              ],
            });
          });

          titleWrap.append(groupMenuButton);
        }
        summary.append(titleWrap, actions);

        if (shortcutEditMode) {
          section.addEventListener("dragover", (event) => {
            const payload = readDragPayload(event);

            if (payload?.type !== "group") {
              return;
            }

            event.preventDefault();
            event.stopPropagation();
            if (event.dataTransfer) {
              event.dataTransfer.dropEffect = "move";
            }
            clearDropIndicators(stack);
            const position = getDropPosition(event, section, "y");
            setDropPosition(section, position, "y");
          });
          section.addEventListener("dragleave", () => {
            clearDropElement(section);
          });
          section.addEventListener("drop", (event) => {
            const payload = readDragPayload(event);

            if (payload?.type !== "group") {
              return;
            }

            event.preventDefault();
            event.stopPropagation();
            clearDropIndicators(stack);

            const position = getDropPosition(event, section, "y");
            const targetIndex = groupIndex + (position === "after" ? 1 : 0);

            if (moveArrayItem(newTabState.shortcutGroups, Number(payload.groupIndex), targetIndex)) {
              persistConfigChange("已排序");
            }
          });
        }

        const items = document.createElement("div");
        items.className = shortcutEditMode
          ? "shortcut-group__items flex w-full max-w-[min(100%,34rem)] min-w-0 flex-wrap items-start justify-start gap-2"
          : "shortcut-group__items flex w-full max-w-[calc((5*2.75rem)+(4*0.5rem))] min-w-0 flex-wrap items-start justify-start gap-2";
        if (shortcutEditMode) {
          items.addEventListener("dragover", (event) => {
            const payload = readDragPayload(event);

            if (payload?.type !== "shortcut") {
              return;
            }

            event.preventDefault();
            event.stopPropagation();
            if (event.dataTransfer) {
              event.dataTransfer.dropEffect = "move";
            }
            clearDropIndicators(stack);
            setDropContainer(items);
          });
          items.addEventListener("dragleave", () => {
            clearDropElement(items);
          });
          items.addEventListener("drop", (event) => {
            const payload = readDragPayload(event);

            if (payload?.type !== "shortcut") {
              return;
            }

            event.preventDefault();
            event.stopPropagation();
            clearDropIndicators(stack);

            if (
              moveShortcutItem(
                Number(payload.groupIndex),
                Number(payload.shortcutIndex),
                groupIndex,
                group.shortcuts.length,
              )
            ) {
              persistConfigChange("已排序");
            }
          });
        }

        group.shortcuts.forEach((shortcut, shortcutIndex) => {
          const itemShell = document.createElement("div");
          itemShell.className = shortcutEditMode
            ? "shortcut-item-shell group relative z-0 h-11 w-11 cursor-grab active:cursor-grabbing hover:z-30 focus-within:z-30"
            : "shortcut-item-shell group relative z-0 h-11 w-11 hover:z-30 focus-within:z-30";

          if (shortcutEditMode) {
            const openShortcutEditForm = () => {
              const form = createShortcutEditForm(group, shortcut);
              itemShell.replaceWith(form);
              focusFirstInput(form);
            };
            const removeShortcut = () => {
              const currentShortcutIndex = group.shortcuts.indexOf(shortcut);

              if (currentShortcutIndex < 0) {
                return;
              }

              group.shortcuts.splice(currentShortcutIndex, 1);
              persistConfigChange("已删除");
            };
            const openShortcutMenu = (event) => {
              openShortcutContextMenu({
                event,
                fallbackElement: itemShell,
                title: shortcut.title,
                subtitle: getShortcutSubtitle(shortcut),
                actions: [
                  {
                    label: "修改 item",
                    icon: "edit",
                    onSelect: openShortcutEditForm,
                  },
                  {
                    label: settingsLabels.removeShortcutLabel ?? "删除 item",
                    icon: "trash",
                    danger: true,
                    onSelect: removeShortcut,
                  },
                ],
              });
            };

            itemShell.draggable = true;
            itemShell.title = `拖拽排序：${shortcut.title}`;
            itemShell.addEventListener("contextmenu", openShortcutMenu);
            itemShell.addEventListener("dragstart", (event) => {
              if (event.target instanceof Element && event.target.closest("button")) {
                event.preventDefault();
                return;
              }

              setDragPayload({
                type: "shortcut",
                groupIndex,
                shortcutIndex,
              });
              if (event.dataTransfer) {
                event.dataTransfer.setData("application/json", JSON.stringify(activeDragPayload));
                event.dataTransfer.setData("text/plain", shortcut.title);
                event.dataTransfer.effectAllowed = "move";
              }
              itemShell.classList.add("opacity-50");
            });
            itemShell.addEventListener("dragend", () => {
              itemShell.classList.remove("opacity-50");
              clearDropIndicators(stack);
              clearDragPayload();
            });

            itemShell.addEventListener("dragover", (event) => {
              const payload = readDragPayload(event);

              if (payload?.type !== "shortcut") {
                return;
              }

              event.preventDefault();
              event.stopPropagation();
              if (event.dataTransfer) {
                event.dataTransfer.dropEffect = "move";
              }
              clearDropIndicators(stack);
              const position = getDropPosition(event, itemShell, "x");
              setDropPosition(itemShell, position);
            });
            itemShell.addEventListener("dragleave", () => {
              clearDropElement(itemShell);
            });
            itemShell.addEventListener("drop", (event) => {
              const payload = readDragPayload(event);

              if (payload?.type !== "shortcut") {
                return;
              }

              event.preventDefault();
              event.stopPropagation();
              clearDropIndicators(stack);

              const position = getDropPosition(event, itemShell, "x");
              const targetIndex = shortcutIndex + (position === "after" ? 1 : 0);

              if (
                moveShortcutItem(
                  Number(payload.groupIndex),
                  Number(payload.shortcutIndex),
                  groupIndex,
                  targetIndex,
                )
              ) {
                persistConfigChange("已排序");
              }
            });
          }

          const item = document.createElement("a");
          item.className = "shortcut-item group/item absolute left-0 top-0 grid h-11 w-11 grid-cols-[1.7rem_0fr] items-center justify-start gap-0 overflow-hidden rounded-[0.45rem] border border-transparent bg-base-100/95 px-2 font-[inherit] text-inherit no-underline transition-[transform,border-color,background-color] duration-180 hover:z-20 hover:-translate-y-0.5 hover:border-base-content/20 hover:bg-base-200 focus-visible:z-20 focus-visible:-translate-y-0.5 focus-visible:border-base-content/20 focus-visible:bg-base-200 focus-visible:outline-none";
          item.href = shortcut.url;
          if (newTabState.shortcutOpenMode === "newTab") {
            item.target = "_blank";
            item.rel = "noopener noreferrer";
