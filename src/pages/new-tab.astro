    const moveArrayItem = (items, fromIndex, toIndex) => {
      if (
        fromIndex < 0 ||
        fromIndex >= items.length ||
        toIndex < 0 ||
        fromIndex === toIndex
      ) {
        return false;
      }

      if (toIndex > items.length) {
        return false;
      }

      const adjustedTargetIndex = fromIndex < toIndex ? toIndex - 1 : toIndex;
      if (adjustedTargetIndex === fromIndex) {
        return false;
      }

      const [item] = items.splice(fromIndex, 1);
      items.splice(Math.min(Math.max(adjustedTargetIndex, 0), items.length), 0, item);
      return true;
    };

    const moveShortcutItem = (fromGroupIndex, fromShortcutIndex, toGroupIndex, toShortcutIndex) => {
      const fromGroup = newTabState.shortcutGroups[fromGroupIndex];
