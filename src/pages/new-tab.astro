    const isRemoteUrl = (value) => /^https?:\/\//i.test(value);

    const getShortcutLogoCacheKey = (url) => {
      try {
        return new URL(url).origin;
      } catch {
        return url;
      }
    };

    const canProxyUrl = (url) => {
      try {
        const { hostname } = new URL(url);
        const normalizedHost = hostname.toLowerCase();

        if (
          normalizedHost === "localhost" ||
          normalizedHost.endsWith(".local") ||
          normalizedHost.endsWith(".lan") ||
          normalizedHost.startsWith("10.") ||
          normalizedHost.startsWith("192.168.")
        ) {
          return false;
        }

        const private172Match = normalizedHost.match(/^172\.(\d+)\./);
        if (private172Match && Number(private172Match[1]) >= 16 && Number(private172Match[1]) <= 31) {
          return false;
        }

        return true;
      } catch {
        return false;
      }
    };

    const resolveShortcutAssetUrl = (assetUrl, baseUrl) => {
      if (!assetUrl) {
        return "";
      }

      if (/^[a-z]+:/i.test(assetUrl)) {
        return assetUrl;
      }

      try {
        return new URL(assetUrl, baseUrl).href;
      } catch {
        return assetUrl;
      }
    };

    const pushLogoCandidate = (candidates, url, withProxy = true) => {
      if (!url || candidates.includes(url)) {
        return;
      }

      if (withProxy && canProxyUrl(url)) {
        const proxyUrl = getProxyUrl(url);
        if (!candidates.includes(proxyUrl)) {
          candidates.push(proxyUrl);
        }
      }

      candidates.push(url);
    };

    const pushLogoCandidates = (candidates, urls, withProxy = true) => {
      urls.forEach((url) => {
        pushLogoCandidate(candidates, url, withProxy);
      });
    };

    const getCachedShortcutLogo = (shortcut) => {
      const cached = shortcutLogoCache[getShortcutLogoCacheKey(shortcut.url)];

      return isPlainObject(cached) ? cached : undefined;
    };

