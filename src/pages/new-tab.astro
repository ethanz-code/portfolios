---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  Check,
  EllipsisVertical,
  GripVertical,
  PencilLine,
  Plus,
  Search,
  Trash2,
  X,
} from "lucide-astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import {
  newTabConfig,
  newTabSearchEngines,
  newTabShortcutGroups,
} from "../data/new-tab-shortcuts";

const defaultNewTabPayload = {
  config: newTabConfig,
  searchEngines: newTabSearchEngines,
  shortcutGroups: newTabShortcutGroups,
};

const serializedDefaultNewTabPayload = JSON.stringify(defaultNewTabPayload).replace(/</g, "\\u003c");
---

<BaseLayout
  title={newTabConfig.title}
  description={newTabConfig.description}
  includeSidebar={false}
  showHeader={false}
  showFooter={false}
  showFloatingThemeToggle={false}
>
  <section
    class="new-tab-shell relative isolate z-10 grid w-[min(100%,58rem)] gap-[clamp(1rem,2.2vw,1.75rem)] max-sm:gap-7"
    aria-labelledby="new-tab-title"
    data-new-tab-page
  >
    <h1 id="new-tab-title" class="sr-only">{newTabConfig.heading}</h1>

    <div
      class="pointer-events-none fixed inset-0 z-[-20] hidden bg-slate-50"
      aria-hidden="true"
      data-new-tab-background-base
    ></div>
    <div
      class="pointer-events-none fixed inset-0 -z-10 hidden bg-center bg-cover bg-no-repeat opacity-0 transition-opacity duration-200"
      aria-hidden="true"
      data-new-tab-background-layer
    ></div>

    <div class="new-tab-toolbar flex max-w-[48rem] items-center justify-between gap-4 max-sm:flex-col max-sm:items-start max-sm:gap-3">
      <div
        class="new-tab-greeting min-h-6 text-sm font-medium text-base-content/70"
        data-new-tab-greeting
        data-new-tab-color-target="navigation"
      ></div>
      <div class="new-tab-actions flex flex-wrap items-center justify-end gap-2 max-sm:justify-start">
        <ThemeToggle mobile={true} />
        <a
          class="btn btn-ghost btn-sm"
          href={newTabConfig.homeLink.href}
          data-home-link
          data-new-tab-color-target="navigation"
        >
          {newTabConfig.homeLink.label}
        </a>
        <button
          class="btn btn-outline btn-sm"
          type="button"
          data-config-open
          data-new-tab-color-target="navigation"
        >
          {newTabConfig.settings.openLabel}
        </button>
      </div>
    </div>

    <form
      class="new-tab-search join grid w-full max-w-[48rem] grid-cols-[minmax(0,1fr)_auto_3.1rem] items-stretch focus-within:ring-1 focus-within:ring-base-content/20 max-sm:grid-cols-[minmax(0,1fr)_3.1rem]"
      role="search"
      data-new-tab-search
    >
      <label class="sr-only" for="new-tab-query">搜索关键词</label>
      <input
        id="new-tab-query"
        class="input input-bordered join-item new-tab-search__input h-[3.25rem] min-w-0 text-base"
        type="search"
        name="q"
        autocomplete="off"
        placeholder={newTabConfig.search.placeholder}
        data-search-query
      />
      <label class="sr-only" for="new-tab-engine">搜索引擎</label>
      <select
        id="new-tab-engine"
        class="select select-bordered join-item new-tab-search__engine h-[3.25rem] max-w-36 max-sm:col-span-full max-sm:row-start-2 max-sm:w-full max-sm:max-w-none"
        name="engine"
        data-search-engine
      ></select>
      <button
        class="btn btn-neutral join-item new-tab-search__submit min-h-[3.25rem] w-[3.25rem]"
        type="submit"
        aria-label={newTabConfig.search.submitLabel}
        title={newTabConfig.search.submitLabel}
      >
        <Search class="h-[1.1rem] w-[1.1rem]" aria-hidden="true" />
      </button>
    </form>

    <div class="shortcut-stack grid gap-[0.55rem]" aria-label="快捷网站" data-shortcut-stack></div>
    <button
      class="shortcut-edit-toggle btn btn-ghost fixed bottom-4 right-4 z-40 h-10 min-h-10 w-10 rounded-full border border-base-content/10 bg-base-100/80 p-0 opacity-60 shadow-sm backdrop-blur transition hover:opacity-100 focus-visible:opacity-100"
      type="button"
      aria-pressed="false"
      aria-label="编辑快捷方式"
      data-shortcut-edit-toggle
    >
      <PencilLine class="h-4 w-4" aria-hidden="true" />
    </button>
  </section>

  <div class="new-tab-config fixed inset-0 z-[80] hidden pointer-events-none opacity-0 transition-opacity duration-200" data-config-drawer>
    <button class="new-tab-config__backdrop absolute inset-0 border-0 bg-base-content/20 opacity-0 transition-opacity duration-200" type="button" aria-label={newTabConfig.settings.closeLabel} data-config-close></button>
    <aside class="new-tab-config__sheet absolute right-0 top-0 grid h-dvh w-[min(100vw,31rem)] max-sm:w-[min(100vw,24rem)] grid-rows-[auto_minmax(0,1fr)_auto] border-l border-base-content/10 bg-base-100 shadow-2xl translate-x-full transition-transform duration-200" aria-label={newTabConfig.settings.panelTitle} aria-modal="true" role="dialog">
      <div class="new-tab-config__header flex items-center justify-between gap-3 border-b border-base-content/10 p-4">
        <div class="min-w-0">
          <h2 class="m-0 text-base font-extrabold leading-tight">{newTabConfig.settings.panelTitle}</h2>
          <p class="mt-1 text-[0.78rem] leading-snug text-base-content/50" data-config-status>{newTabConfig.settings.statusReady}</p>
        </div>
        <button class="btn btn-square btn-ghost btn-sm" type="button" aria-label={newTabConfig.settings.closeLabel} data-config-close>
          <X class="h-4 w-4" aria-hidden="true" />
        </button>
      </div>

      <div class="new-tab-config__body grid content-start gap-4 overflow-y-auto p-4">
        <section class="new-tab-config__section grid gap-3">
          <div class="new-tab-config__section-title text-sm font-extrabold leading-5 text-base-content">{newTabConfig.settings.generalLabel}</div>
          <div class="new-tab-config__grid grid grid-cols-2 gap-3 max-sm:grid-cols-1">
            <label class="form-control grid min-w-0 gap-1.5">
              <span class="label">
                <span class="label-text">{newTabConfig.settings.nameLabel}</span>
              </span>
              <input class="input input-bordered input-sm" type="text" autocomplete="off" data-config-name />
            </label>
            <label class="form-control grid min-w-0 gap-1.5">
              <span class="label">
                <span class="label-text">{newTabConfig.settings.homeLinkLabel}</span>
              </span>
              <input class="input input-bordered input-sm" type="text" autocomplete="off" data-config-home-label />
            </label>
            <label class="form-control grid min-w-0 gap-1.5">
              <span class="label">
                <span class="label-text">{newTabConfig.settings.homeHrefLabel}</span>
              </span>
              <input class="input input-bordered input-sm" type="text" autocomplete="off" data-config-home-href />
            </label>
            <label class="form-control grid min-w-0 gap-1.5 col-span-full">
              <span class="label">
                <span class="label-text">{newTabConfig.settings.shortcutOpenModeLabel}</span>
              </span>
              <select class="select select-bordered select-sm" data-config-shortcut-open-mode>
                <option value="current">{newTabConfig.settings.shortcutOpenModeCurrentLabel}</option>
                <option value="newTab">{newTabConfig.settings.shortcutOpenModeNewTabLabel}</option>
              </select>
            </label>
            <label class="form-control grid min-w-0 gap-1.5 col-span-full">
              <span class="label">
                <span class="label-text">{newTabConfig.settings.backgroundUrlLabel}</span>
              </span>
              <input
                class="input input-bordered input-sm"
                type="url"
                placeholder={newTabConfig.settings.backgroundPlaceholder}
                data-config-background
              />
            </label>
            <label class="form-control grid min-w-0 gap-1.5 col-span-full">
              <span class="label">
                <span class="label-text">{newTabConfig.settings.backgroundFileLabel}</span>
              </span>
              <div class="new-tab-config-upload flex min-w-0 items-center gap-2">
                <input hidden type="file" accept="image/*" data-config-background-file />
                <button class="btn btn-outline btn-sm" type="button" data-config-background-file-trigger>
                  {newTabConfig.settings.backgroundFileLabel}
                </button>
                <span class="truncate text-[0.78rem] leading-snug text-base-content/55" data-config-background-status>{newTabConfig.settings.backgroundEmptyLabel}</span>
              </div>
            </label>
            <label class="form-control grid min-w-0 gap-1.5 col-span-full">
              <span class="label">
                <span class="label-text">{newTabConfig.settings.backgroundOpacityLabel}</span>
                <span class="label-text-alt" data-config-background-opacity-value></span>
              </span>
              <input
                class="range range-xs"
                type="range"
                min="0"
                max="100"
                step="1"
                data-config-background-opacity
              />
            </label>
            <div class="new-tab-config__wide new-tab-config__section-title col-span-full text-sm font-extrabold leading-5 text-base-content">
              {newTabConfig.settings.textColorLabel}
            </div>
            <label class="form-control grid min-w-0 gap-1.5 col-span-full">
              <span class="label">
                <span class="label-text">{newTabConfig.settings.textColorModeLabel}</span>
              </span>
              <select class="select select-bordered select-sm" data-config-text-color-mode>
                <option value="default">{newTabConfig.settings.textColorDefaultLabel}</option>
                <option value="light">{newTabConfig.settings.textColorLightLabel}</option>
                <option value="dark">{newTabConfig.settings.textColorDarkLabel}</option>
                <option value="custom">{newTabConfig.settings.textColorCustomLabel}</option>
              </select>
            </label>
            <label class="form-control grid min-w-0 gap-1.5">
              <span class="label">
                <span class="label-text">{newTabConfig.settings.navigationTextColorLabel}</span>
              </span>
              <input class="input input-bordered input-sm h-10 p-1" type="color" data-config-navigation-color />
            </label>
            <label class="form-control grid min-w-0 gap-1.5">
              <span class="label">
                <span class="label-text">{newTabConfig.settings.itemLabelTextColorLabel}</span>
              </span>
              <input class="input input-bordered input-sm h-10 p-1" type="color" data-config-item-label-color />
            </label>
          </div>
        </section>

      </div>

      <div class="new-tab-config__footer flex flex-wrap items-center justify-start gap-3 border-t border-base-content/10 p-4">
        <input
          hidden
          type="file"
          accept="application/json,.json"
          aria-label={newTabConfig.settings.fileLabel}
          data-config-file
        />
        <button class="btn btn-sm btn-outline" type="button" data-config-import>
          {newTabConfig.settings.importLabel}
        </button>
        <button class="btn btn-sm btn-outline" type="button" data-config-export>
          {newTabConfig.settings.exportLabel}
        </button>
        <button class="btn btn-sm btn-ghost" type="button" data-config-clear-background>
          {newTabConfig.settings.clearBackgroundLabel}
        </button>
        <button class="btn btn-sm btn-ghost" type="button" data-config-reset>
          {newTabConfig.settings.resetLabel}
        </button>
      </div>
    </aside>
  </div>

  <template data-new-tab-icon="check">
    <Check class="h-3.5 w-3.5" aria-hidden="true" />
  </template>
  <template data-new-tab-icon="close">
    <X class="h-3.5 w-3.5" aria-hidden="true" />
  </template>
  <template data-new-tab-icon="drag">
    <GripVertical class="h-3.5 w-3.5" aria-hidden="true" />
  </template>
  <template data-new-tab-icon="more">
    <EllipsisVertical class="h-4 w-4" aria-hidden="true" />
  </template>
  <template data-new-tab-icon="edit">
    <PencilLine class="h-4 w-4" aria-hidden="true" />
  </template>
  <template data-new-tab-icon="plus">
    <Plus class="h-4 w-4" aria-hidden="true" />
  </template>
  <template data-new-tab-icon="trash">
    <Trash2 class="h-3.5 w-3.5" aria-hidden="true" />
  </template>

  <script is:inline type="application/json" id="new-tab-defaults" set:html={serializedDefaultNewTabPayload} />

  <script>
    // @ts-nocheck
    const defaultPayloadElement = document.getElementById("new-tab-defaults");
    const defaultPayload = defaultPayloadElement?.textContent
      ? JSON.parse(defaultPayloadElement.textContent)
      : {};

    const cloneValue = (value) => {
      if (typeof structuredClone === "function") {
        return structuredClone(value);
      }

      return JSON.parse(JSON.stringify(value));
    };

    const configVersion = 7;
    const defaultBackgroundOpacity = 60;
    const oldDefaultBackgroundOpacities = [34, 50];
    const defaultTextColors = {
      mode: "default",
      navigationColor: "#f8fafc",
      itemLabelColor: "#f8fafc",
    };

    const defaultState = () => ({
      version: configVersion,
      userName: defaultPayload.config?.userName ?? "Ethanz888",
      backgroundImage: "",
      backgroundOpacity: defaultBackgroundOpacity,
      textColors: cloneValue(defaultTextColors),
      defaultSearchEngineId: defaultPayload.config?.search?.defaultEngineId ?? "google",
      homeLink: cloneValue(defaultPayload.config?.homeLink ?? { label: "资料卡首页", href: "/" }),
      shortcutOpenMode: "current",
      greetings: cloneValue(defaultPayload.config?.greetings ?? []),
      searchEngines: cloneValue(defaultPayload.searchEngines ?? []),
      shortcutGroups: cloneValue(defaultPayload.shortcutGroups ?? []),
    });

    const storageKey = defaultPayload.config?.storageKey ?? "ethanz-new-tab-config";
    const logoCacheStorageKey = `${storageKey}:logo-cache`;
    const logoResolverVersion = 4;
    const settingsLabels = defaultPayload.config?.settings ?? {};
    let newTabState = defaultState();
    let shortcutEditMode = false;
    let activeDragPayload = null;
    let textColorSaveTimer = 0;
    let shortcutLogoCache = {};
    let activeShortcutContextMenu = null;
    const shortcutLogoRequests = new Map();
    const onePanelLogoDataUrl = `data:image/svg+xml,${encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 33 33" fill="#3370ff"><path d="M19.42 4.842 7.785 11.56v10.064l7.539 4.353-2.921 1.686-7.54-4.353V9.874L16.5 3.156z"/><path d="m20.598 5.522-2.921 1.686 7.539 4.352v10.064l2.92 1.686V9.874zM16.922 9.328l.892.532v13.666l-.892.515zM12.523 11.862l4.399-2.534-.002 14.714-2.848-1.644v-8.82h-1.549z"/><path fill-rule="evenodd" d="M3 8.796 16.5 1 30 8.796v15.592l-13.5 7.796L3 24.388zm26.64.208L16.5 1.417V1.41L3.357 8.997v15.182L16.5 31.772l13.141-7.587z" clip-rule="evenodd"/></svg>')}`;

    const isPlainObject = (value) =>
      value !== null && typeof value === "object" && !Array.isArray(value);

    const normalizeText = (value, fallback = "") =>
      typeof value === "string" && value.trim() ? value.trim() : fallback;

    const normalizeMaybeText = (value) =>
      typeof value === "string" && value.trim() ? value.trim() : undefined;

    const normalizeColor = (value, fallback) =>
      typeof value === "string" && /^#[0-9a-fA-F]{6}$/.test(value.trim())
        ? value.trim()
        : fallback;

    const normalizeShortcutOpenMode = (value, fallback = "current") =>
      value === "newTab" || value === "current" ? value : fallback;

    const normalizeTextColors = (value, fallback) => {
      if (!isPlainObject(value)) {
        return cloneValue(fallback);
      }

      const mode = ["default", "light", "dark", "custom"].includes(value.mode)
        ? value.mode
        : fallback.mode;

      return {
        mode,
        navigationColor: normalizeColor(
          value.navigationColor ?? value.greetingColor ?? value.homeLinkColor,
          fallback.navigationColor,
        ),
        itemLabelColor: normalizeColor(
          value.itemLabelColor ?? value.shortcutLabelColor,
          fallback.itemLabelColor,
        ),
      };
    };

    const normalizeGreetings = (greetings, fallback) => {
      if (!Array.isArray(greetings)) {
        return cloneValue(fallback);
      }

      const normalized = greetings
        .map((item) => ({
          label: normalizeText(item?.label),
          from: Number(item?.from),
          to: Number(item?.to),
        }))
        .filter((item) =>
          item.label &&
          Number.isInteger(item.from) &&
          Number.isInteger(item.to) &&
          item.from >= 0 &&
          item.from <= 23 &&
          item.to >= 0 &&
          item.to <= 23
        );

      return normalized.length ? normalized : cloneValue(fallback);
    };

    const normalizeSearchEngines = (engines, fallback) => {
      if (!Array.isArray(engines)) {
        return cloneValue(fallback);
      }

      const ids = new Set();
      const normalized = engines
        .map((engine) => ({
          id: normalizeText(engine?.id),
          label: normalizeText(engine?.label),
          searchUrl: normalizeText(engine?.searchUrl),
        }))
        .filter((engine) => {
          if (!engine.id || !engine.label || !engine.searchUrl.includes("{query}") || ids.has(engine.id)) {
            return false;
          }

          ids.add(engine.id);
          return true;
        });

      return normalized.length ? normalized : cloneValue(fallback);
    };

    const normalizeShortcutGroups = (groups, fallback) => {
      if (!Array.isArray(groups)) {
        return cloneValue(fallback);
      }

      const normalized = groups
        .map((group) => ({
          title: normalizeText(group?.title),
          shortcuts: Array.isArray(group?.shortcuts)
            ? group.shortcuts
                .map((shortcut) => ({
                  title: normalizeText(shortcut?.title),
                  url: normalizeText(shortcut?.url),
                  description: normalizeMaybeText(shortcut?.description),
                  logo: normalizeMaybeText(shortcut?.logo),
                }))
                .filter((shortcut) => shortcut.title && shortcut.url)
            : [],
        }))
        .filter((group) => group.title);

      return normalized.length ? normalized : cloneValue(fallback);
    };

    const normalizeHomeLink = (homeLink, fallback) => {
      if (!isPlainObject(homeLink)) {
        return cloneValue(fallback);
      }

      return {
        label: normalizeText(homeLink.label, fallback.label),
        href: normalizeText(homeLink.href, fallback.href),
      };
    };

    const normalizeNewTabState = (value) => {
      const fallback = defaultState();

      if (!isPlainObject(value)) {
        return fallback;
      }

      const searchEngines = normalizeSearchEngines(value.searchEngines, fallback.searchEngines);
      const defaultSearchEngineId = normalizeText(
        value.defaultSearchEngineId ?? value.search?.defaultEngineId,
        fallback.defaultSearchEngineId,
      );

      return {
        version: configVersion,
        userName: normalizeText(value.userName, fallback.userName),
        backgroundImage: typeof value.backgroundImage === "string" ? value.backgroundImage.trim() : "",
        backgroundOpacity: Number.isFinite(Number(value.backgroundOpacity))
          ? Math.min(100, Math.max(0, Number(value.backgroundOpacity)))
          : fallback.backgroundOpacity,
        textColors: normalizeTextColors(value.textColors, fallback.textColors),
        defaultSearchEngineId: searchEngines.some((engine) => engine.id === defaultSearchEngineId)
          ? defaultSearchEngineId
          : searchEngines[0]?.id ?? fallback.defaultSearchEngineId,
        homeLink: normalizeHomeLink(value.homeLink, fallback.homeLink),
        shortcutOpenMode: normalizeShortcutOpenMode(value.shortcutOpenMode, fallback.shortcutOpenMode),
        greetings: normalizeGreetings(value.greetings, fallback.greetings),
        searchEngines,
        shortcutGroups: normalizeShortcutGroups(value.shortcutGroups, fallback.shortcutGroups),
      };
    };

    const readStoredState = () => {
      try {
        const storedConfig = window.localStorage.getItem(storageKey);

        if (!storedConfig) {
          return defaultState();
        }

        const parsedConfig = JSON.parse(storedConfig);
        const storedState = normalizeNewTabState(parsedConfig);

        if (Number(parsedConfig?.version ?? 1) < configVersion) {
          storedState.shortcutGroups = [];
          window.localStorage.setItem(storageKey, JSON.stringify(storedState));
        }

        if (
          Number(parsedConfig?.version ?? 1) < configVersion &&
          oldDefaultBackgroundOpacities.includes(storedState.backgroundOpacity)
        ) {
          storedState.backgroundOpacity = defaultBackgroundOpacity;
          window.localStorage.setItem(storageKey, JSON.stringify(storedState));
        }

        return storedState;
      } catch {
        return defaultState();
      }
    };

    const writeStoredState = () => {
      try {
        window.localStorage.setItem(storageKey, JSON.stringify(newTabState));
      } catch {
        // The page still works with the in-memory config when storage is unavailable.
      }
    };

    const readShortcutLogoCache = () => {
      try {
        const cache = JSON.parse(window.localStorage.getItem(logoCacheStorageKey) ?? "{}");

        return isPlainObject(cache) ? cache : {};
      } catch {
        return {};
      }
    };

    const writeShortcutLogoCache = () => {
      try {
        window.localStorage.setItem(logoCacheStorageKey, JSON.stringify(shortcutLogoCache));
      } catch {
        // Logo discovery is an enhancement; shortcuts still work without the cache.
      }
    };

    const getShortcutHostname = (url) => {
      try {
        return new URL(url).hostname.replace(/^www\./, "");
      } catch {
        return url;
      }
    };

    const getShortcutInitial = (title) => title.trim().slice(0, 1).toUpperCase();

    const normalizeShortcutUrlInput = (value) => {
      const url = normalizeText(value);

      if (!url) {
        return "";
      }

      if (/^(https?:|mailto:|tel:|\/|#)/i.test(url)) {
        return url;
      }

      return `https://${url}`;
    };

    const isValidShortcutUrl = (url) => {
      if (/^(\/|#)/.test(url)) {
        return true;
      }

      try {
        new URL(url);
        return true;
      } catch {
        return false;
      }
    };

    const focusFirstInput = (element) => {
      window.requestAnimationFrame(() => {
        element.querySelector("input")?.focus();
      });
    };

    const setInlineFormError = (target, message) => {
      target.textContent = message;
      target.classList.remove("hidden");
    };

    const clearInlineFormError = (target) => {
      target.textContent = "";
      target.classList.add("hidden");
    };

    const getIconMarkup = (name) => {
      const template = document.querySelector(`template[data-new-tab-icon="${name}"]`);

      return template instanceof HTMLTemplateElement ? template.innerHTML.trim() : "";
    };

    const createIconButton = (label, iconName, extraClasses = "") => {
      const button = document.createElement("button");
      button.className = `btn btn-square btn-ghost btn-xs h-8 min-h-8 w-8 p-0 text-base-content/60 transition hover:text-base-content focus-visible:text-base-content [&_svg]:h-3.5 [&_svg]:w-3.5 ${extraClasses}`;
      button.type = "button";
      button.title = label;
      button.setAttribute("aria-label", label);
      button.innerHTML = getIconMarkup(iconName);
      return button;
    };

    const closeShortcutContextMenu = () => {
      activeShortcutContextMenu?.remove();
      activeShortcutContextMenu = null;
    };

    const getContextMenuPoint = (event, fallbackElement) => {
      if (event instanceof MouseEvent && Number.isFinite(event.clientX) && Number.isFinite(event.clientY)) {
        return {
          x: event.clientX,
          y: event.clientY,
        };
      }

      const rect = fallbackElement?.getBoundingClientRect();
      return {
        x: rect ? rect.left + rect.width / 2 : window.innerWidth / 2,
        y: rect ? rect.bottom + 8 : window.innerHeight / 2,
      };
    };

    const positionShortcutContextMenu = (menu, point) => {
      const margin = 12;
      const rect = menu.getBoundingClientRect();
      const maxLeft = Math.max(margin, window.innerWidth - rect.width - margin);
      const maxTop = Math.max(margin, window.innerHeight - rect.height - margin);

      menu.style.left = `${Math.min(Math.max(point.x, margin), maxLeft)}px`;
      menu.style.top = `${Math.min(Math.max(point.y, margin), maxTop)}px`;
    };

    const openShortcutContextMenu = ({ event, fallbackElement, title, subtitle, actions }) => {
      event?.preventDefault();
      event?.stopPropagation();
