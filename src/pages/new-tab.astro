      toggle.setAttribute("aria-pressed", String(shortcutEditMode));
      toggle.title = shortcutEditMode ? "完成" : "编辑";
      toggle.setAttribute("aria-label", shortcutEditMode ? "完成编辑" : "编辑快捷方式");
      toggle.innerHTML = shortcutEditMode
        ? `
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" aria-hidden="true">
