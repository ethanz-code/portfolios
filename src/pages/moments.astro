---
import BaseLayout from "../layouts/BaseLayout.astro";
import MomentMosaic from "../components/MomentMosaic.astro";
import { momentGroups, momentImages } from "../data/moments";
---

<BaseLayout
  title="近期影像"
  description="近期图片档案，按构建时自动生成的九宫格和分组展示。"
  sideBarActiveItemID="moments"
>
  <h1 class="sr-only">近期影像</h1>

  <MomentMosaic
    images={momentImages}
    title=""
    description=""
    ariaLabel="近期影像随机预览"
    showMeta={false}
    previewGrid
    galleryId="moments-preview"
  />

  {
    momentGroups.length > 0 && (
      <section class="mt-[clamp(3rem,8vw,5rem)]" aria-label="分组影像">
        <div class="mb-[clamp(1.5rem,4vw,2.25rem)] flex items-center gap-4" aria-hidden="true">
          <span class="h-px flex-1 bg-[color-mix(in_srgb,oklch(var(--bc))_16%,transparent)]" />
          <span class="shrink-0 text-sm leading-6 text-[color-mix(in_srgb,oklch(var(--bc))_58%,transparent)]">
            {momentGroups.length} 组 · {momentImages.length} 张
          </span>
        </div>

        <div class="grid gap-[clamp(2.75rem,7vw,4.5rem)]">
          {
            momentGroups.map((group) => (
              <section class="grid gap-4" aria-label={group.title}>
                <div class="flex items-end justify-between gap-4 border-t border-[color-mix(in_srgb,oklch(var(--bc))_16%,transparent)] pt-4 max-sm:flex-col-reverse max-sm:items-start max-sm:gap-2">
                  {group.description && (
                    <p class="m-0 max-w-[42rem] leading-7 text-[color-mix(in_srgb,oklch(var(--bc))_72%,transparent)]">
                      {group.description}
                    </p>
                  )}
                  <div class="flex shrink-0 gap-3 whitespace-nowrap text-sm leading-6 text-[color-mix(in_srgb,oklch(var(--bc))_58%,transparent)] max-sm:w-full max-sm:justify-between">
                    {group.date && <time datetime={group.date}>{group.date}</time>}
                    <span>{group.images.length} 张</span>
                  </div>
                </div>

                <MomentMosaic
                  images={group.images}
                  title=""
                  description=""
                  ariaLabel={`${group.title}影像`}
                  showMeta={false}
                  compact
                  galleryId={`moments-${group.slug}`}
                />
              </section>
            ))
          }
        </div>
      </section>
    )
  }
</BaseLayout>
