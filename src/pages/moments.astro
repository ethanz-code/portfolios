---
import BaseLayout from "../layouts/BaseLayout.astro";
import MomentMosaic from "../components/MomentMosaic.astro";
import { momentGroups, momentImages } from "../data/moments";
---

<BaseLayout
  title="近期影像"
  description="近期图片档案，按构建时自动生成的九宫格和图片组展示。"
  sideBarActiveItemID="moments"
>
  <h1 class="sr-only">近期影像</h1>

  <MomentMosaic
    images={momentImages}
    title=""
    description=""
  />

  {
    momentGroups.length > 0 && (
      <section class="mt-16">
        <h2 class="mb-6 text-xl font-bold leading-tight sm:text-2xl lg:text-3xl">图片组</h2>
        <div class="grid gap-12">
          {
            momentGroups.map((group) => (
              <section>
                <div class="mb-4 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
                  <div>
                    <h3 class="text-lg font-bold leading-tight sm:text-xl">{group.title}</h3>
                    {
                      group.description && (
                        <p class="mt-2 max-w-2xl leading-7 opacity-75">{group.description}</p>
                      )
                    }
                  </div>
                  <div class="text-sm opacity-65">
                    {group.date && <time datetime={group.date}>{group.date}</time>}
                    {group.date && " · "}
                    {group.images.length} 张
                  </div>
                </div>

                <MomentMosaic
                  images={group.images}
                  title=""
                  description=""
                  showMeta={false}
                  compact
                />
              </section>
            ))
          }
        </div>
      </section>
    )
  }
</BaseLayout>
