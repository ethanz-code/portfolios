---
import BaseLayout from "../layouts/BaseLayout.astro";
import MomentMosaic from "../components/MomentMosaic.astro";
import { momentGroups, momentImages } from "../data/moments";
---

<BaseLayout
  title="近期影像"
  description="近期图片档案，按构建时自动生成的九宫格和分组展示。"
  sideBarActiveItemID="moments"
>
  <h1 class="sr-only">近期影像</h1>

  <MomentMosaic
    images={momentImages}
    title=""
    description=""
    ariaLabel="近期影像随机预览"
    showMeta={false}
    previewGrid
    galleryId="moments-preview"
  />

  {
    momentGroups.length > 0 && (
      <section class="moments-archive" aria-label="分组影像">
        <div class="moments-archive__divider" aria-hidden="true">
          <span class="moments-archive__line" />
          <span class="moments-archive__count">{momentGroups.length} 组 · {momentImages.length} 张</span>
        </div>

        <div class="moment-group-list">
          {
            momentGroups.map((group) => (
              <section class="moment-group" aria-label={group.title}>
                <div class="moment-group__meta">
                  {group.description && <p class="moment-group__description">{group.description}</p>}
                  <div class="moment-group__facts">
                    {group.date && <time datetime={group.date}>{group.date}</time>}
                    <span>{group.images.length} 张</span>
                  </div>
                </div>

                <MomentMosaic
                  images={group.images}
                  title=""
                  description=""
                  ariaLabel={`${group.title}影像`}
                  showMeta={false}
                  compact
                  galleryId={`moments-${group.slug}`}
                />
              </section>
            ))
          }
        </div>
      </section>
    )
  }
</BaseLayout>
