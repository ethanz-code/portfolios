---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SideBar from "../components/SideBar.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { ClientRouter } from "astro:transitions";

import { SITE_TITLE, SITE_DESCRIPTION, TRANSITION_API } from "../config";

const {
  image,
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  includeSidebar = true,
  showHeader = true,
  showFooter = true,
  showFloatingThemeToggle = true,
  sideBarActiveItemID,
  ogType,
} = Astro.props;

const enableClientRouter = TRANSITION_API && typeof ClientRouter !== "undefined";
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head>
    <script is:inline>
      (() => {
        const storageKey = "theme-preference";
        const getSystemTheme = () =>
          window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        const getDaisyTheme = (theme) => (theme === "dark" ? "black" : "light");
        const getColorScheme = (theme) => (theme === "dark" ? "dark" : "light");

        try {
          const storedTheme = window.localStorage.getItem(storageKey);
          const theme = storedTheme === "light" || storedTheme === "dark" ? storedTheme : getSystemTheme();
          document.documentElement.dataset.theme = getDaisyTheme(theme);
          document.documentElement.style.colorScheme = getColorScheme(theme);
        } catch {
          const theme = getSystemTheme();
          document.documentElement.dataset.theme = getDaisyTheme(theme);
          document.documentElement.style.colorScheme = getColorScheme(theme);
        }
      })();
    </script>
    <BaseHead title={title} description={description} image={image} , ogType={ogType} />
    {enableClientRouter && <ClientRouter />}
  </head>
  <body class="min-h-screen overflow-x-clip bg-base-100 text-base-content">
    <div class:list={[
      "max-w-full overflow-x-clip bg-base-100",
      includeSidebar
        ? "drawer lg:drawer-open lg:grid lg:h-screen lg:grid-cols-[19rem_minmax(0,1fr)] lg:overflow-hidden"
        : "min-h-screen",
    ]}>
      <input id="my-drawer" type="checkbox" class="drawer-toggle" />
      <div
        class:list={[
          "max-w-full overflow-x-clip bg-base-100",
          includeSidebar
            ? "drawer-content flex min-h-screen flex-col lg:col-start-2 lg:h-screen lg:overflow-y-auto"
            : "flex min-h-screen flex-col",
        ]}
      >
        {showHeader && <Header title={SITE_TITLE} showDrawerToggle={includeSidebar} />}
        <div class="flex-1">
          <main class="mx-auto w-full min-w-0 max-w-5xl px-4 pb-10 pt-6 sm:px-6 sm:pb-12 sm:pt-8 lg:px-12 lg:pb-16 lg:pt-16">
            <slot />
          </main>
        </div>
        {showFooter && <Footer />}
      </div>
      {includeSidebar && <SideBar sideBarActiveItemID={sideBarActiveItemID} />}
    </div>
    {
      showFloatingThemeToggle && (
        <div class="fixed right-6 top-6 z-40 hidden lg:block">
          <ThemeToggle />
        </div>
      )
    }
    <button
      type="button"
      class="btn btn-square btn-neutral pointer-events-none fixed bottom-[calc(1rem+env(safe-area-inset-bottom))] right-4 z-40 translate-y-3 scale-95 opacity-0 shadow-lg transition duration-200 ease-out hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-base-content lg:bottom-6 lg:right-6"
      aria-label="回到顶部"
      aria-hidden="true"
      data-back-to-top
      disabled
      tabindex="-1"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.8"
        stroke="currentColor"
        class="h-5 w-5"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" />
      </svg>
    </button>
    <script is:inline>
      (() => {
        const storageKey = "theme-preference";
        const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");

        const getSystemTheme = () => (mediaQuery.matches ? "dark" : "light");

        const getStoredTheme = () => {
          try {
            const value = window.localStorage.getItem(storageKey);
            return value === "light" || value === "dark" ? value : null;
          } catch {
            return null;
          }
        };

        const getDaisyTheme = (theme) => (theme === "dark" ? "black" : "light");
        const getColorScheme = (theme) => (theme === "dark" ? "dark" : "light");

        const applyTheme = (theme) => {
          document.documentElement.dataset.theme = getDaisyTheme(theme);
          document.documentElement.style.colorScheme = getColorScheme(theme);
          const storedTheme = getStoredTheme();

          document.querySelectorAll("[data-theme-option]").forEach((option) => {
            if (!(option instanceof HTMLButtonElement)) {
              return;
            }

            const optionTheme = option.dataset.themeOption;
            const isActive = storedTheme
              ? optionTheme === storedTheme
              : optionTheme === "system";

            option.classList.toggle("bg-base-200", isActive);
            option.classList.toggle("font-medium", isActive);
            option.setAttribute("aria-pressed", isActive ? "true" : "false");
          });

          document.querySelectorAll("[data-theme-selected]").forEach((badge) => {
            if (!(badge instanceof HTMLElement)) {
              return;
            }

            badge.classList.toggle("hidden", badge.dataset.themeSelected !== (storedTheme ?? "system"));
          });
        };

        const bindThemeControls = () => {
          document.querySelectorAll("[data-theme-option]").forEach((option) => {
            if (!(option instanceof HTMLButtonElement) || option.dataset.themeBound === "true") {
              return;
            }

            option.addEventListener("click", () => {
              const selectedTheme = option.dataset.themeOption;

              try {
                if (selectedTheme === "light" || selectedTheme === "dark") {
                  window.localStorage.setItem(storageKey, selectedTheme);
                } else {
                  window.localStorage.removeItem(storageKey);
                }
              } catch {
                // Ignore storage write failures and keep applying the selected theme.
              }

              const resolvedTheme = selectedTheme === "light" || selectedTheme === "dark"
                ? selectedTheme
                : getSystemTheme();

              applyTheme(resolvedTheme);
              option.blur();
            });

            option.dataset.themeBound = "true";
          });

          applyTheme(getStoredTheme() ?? getSystemTheme());
        };

        if (!window.__themePreferenceBound) {
          mediaQuery.addEventListener("change", () => {
            if (!getStoredTheme()) {
              applyTheme(getSystemTheme());
            }
          });

          document.addEventListener("astro:after-swap", bindThemeControls);
          window.__themePreferenceBound = true;
        }

        bindThemeControls();
      })();
    </script>
    <script is:inline>
      (() => {
        const hashToId = () => {
          const hash = window.location.hash.slice(1);

          if (!hash) {
            return "";
          }

          try {
            return decodeURIComponent(hash);
          } catch {
            return hash;
          }
        };

        const getHashTarget = () => {
          const id = hashToId();

          if (!id) {
            return null;
          }

          return document.getElementById(id) ?? document.getElementById(window.location.hash.slice(1));
        };

        const getScrollContainer = (target) => {
          let current = target.parentElement;

          while (current && current !== document.body) {
            const style = window.getComputedStyle(current);
            const canScroll = /(auto|scroll|overlay)/.test(style.overflowY);

            if (canScroll && current.scrollHeight > current.clientHeight) {
              return current;
            }

            current = current.parentElement;
          }

          return document.scrollingElement ?? document.documentElement;
        };

        const getScrollMarginTop = (target) => {
          const margin = Number.parseFloat(window.getComputedStyle(target).scrollMarginTop);
          return Number.isFinite(margin) ? margin : 0;
        };

        const scrollHashTargetIntoView = () => {
          const target = getHashTarget();

          if (!target) {
            return;
          }

          window.requestAnimationFrame(() => {
            const scrollContainer = getScrollContainer(target);
            const marginTop = getScrollMarginTop(target);

            if (
              scrollContainer === document.scrollingElement ||
              scrollContainer === document.documentElement ||
              scrollContainer === document.body
            ) {
              window.scrollTo({
                top: target.getBoundingClientRect().top + window.scrollY - marginTop,
                behavior: "auto",
              });
              return;
            }

            scrollContainer.scrollTo({
              top:
                target.getBoundingClientRect().top -
                scrollContainer.getBoundingClientRect().top +
                scrollContainer.scrollTop -
                marginTop,
              behavior: "auto",
            });
          });
        };

        const scheduleHashScroll = () => {
          [0, 80, 250, 700].forEach((delay) => {
            window.setTimeout(scrollHashTargetIntoView, delay);
          });
        };

        if (!window.__contentHashScrollBound) {
          document.addEventListener("astro:page-load", scheduleHashScroll);
          document.addEventListener("astro:after-swap", scheduleHashScroll);
          window.addEventListener("hashchange", scheduleHashScroll);
          window.addEventListener("load", scheduleHashScroll);
          document.addEventListener("click", (event) => {
            const target = event.target;

            if (!(target instanceof Element)) {
              return;
            }

            const anchor = target.closest(".heading-anchor[href^='#']");

            if (anchor) {
              scheduleHashScroll();
            }
          });

          window.__contentHashScrollBound = true;
        }

        scheduleHashScroll();
      })();
    </script>
    <script is:inline>
      (() => {
        const storagePrefix = "article-scroll:";
        const restoreDelays = [0, 80, 250, 700];

        const normalizePath = (pathname) => pathname.replace(/\/+$/, "") || "/";
        const isArticlePath = (pathname) => {
          const path = normalizePath(pathname);
          return path === "/articles" || path.startsWith("/articles/");
        };
        const isArticleIndexPath = (pathname) => normalizePath(pathname) === "/articles";
        const getStorageKey = (pathname) => `${storagePrefix}${normalizePath(pathname)}`;

        const getPageScrollContainer = () => {
          const drawerContent = document.querySelector(".drawer-content");

          if (drawerContent instanceof HTMLElement) {
            const style = window.getComputedStyle(drawerContent);
            const canScroll = /(auto|scroll|overlay)/.test(style.overflowY);

            if (canScroll && drawerContent.scrollHeight > drawerContent.clientHeight) {
              return drawerContent;
            }
          }

          return document.scrollingElement ?? document.documentElement;
        };

        const getCurrentScrollTop = () => {
          const scrollContainer = getPageScrollContainer();

          if (
            scrollContainer === document.scrollingElement ||
            scrollContainer === document.documentElement ||
            scrollContainer === document.body
          ) {
            return window.scrollY;
          }

          return scrollContainer.scrollTop;
        };

        const setCurrentScrollTop = (top) => {
          const scrollContainer = getPageScrollContainer();

          if (
            scrollContainer === document.scrollingElement ||
            scrollContainer === document.documentElement ||
            scrollContainer === document.body
          ) {
            window.scrollTo({ top, behavior: "auto" });
            return;
          }

          scrollContainer.scrollTo({ top, behavior: "auto" });
        };

        const saveScrollPosition = (pathname = window.location.pathname) => {
          if (!isArticlePath(pathname)) {
            return;
          }

          try {
            window.sessionStorage.setItem(
              getStorageKey(pathname),
              JSON.stringify({ top: getCurrentScrollTop(), updatedAt: Date.now() }),
            );
          } catch {
            // Keep navigation working when sessionStorage is unavailable.
          }
        };

        const shouldRestoreCurrentPath = () => {
          if (!isArticlePath(window.location.pathname) || window.location.hash) {
            return false;
          }

          if (isArticleIndexPath(window.location.pathname)) {
            return true;
          }

          const lastNavigation = window.__articleScrollLastNavigation;
          const navigationEntries = performance.getEntriesByType?.("navigation") ?? [];
          const documentNavigationType = navigationEntries[0]?.type;

          return lastNavigation?.navigationType === "traverse" || documentNavigationType === "back_forward";
        };

        const restoreCurrentScrollPosition = () => {
          if (!shouldRestoreCurrentPath()) {
            return;
          }

          let savedPosition = null;

          try {
            savedPosition = JSON.parse(window.sessionStorage.getItem(getStorageKey(window.location.pathname)) ?? "null");
          } catch {
            savedPosition = null;
          }

          if (!savedPosition || !Number.isFinite(savedPosition.top)) {
            return;
          }

          restoreDelays.forEach((delay) => {
            window.setTimeout(() => setCurrentScrollTop(savedPosition.top), delay);
          });
        };

        if (!window.__articleScrollRestorationBound) {
          document.addEventListener("astro:before-preparation", (event) => {
            saveScrollPosition(event.from?.pathname);
            window.__articleScrollLastNavigation = {
              navigationType: event.navigationType,
              toPathname: event.to?.pathname,
            };
          });
          document.addEventListener("astro:page-load", restoreCurrentScrollPosition);
          document.addEventListener("astro:after-swap", restoreCurrentScrollPosition);
          window.addEventListener("pagehide", () => saveScrollPosition());
          document.addEventListener("visibilitychange", () => {
            if (document.visibilityState === "hidden") {
              saveScrollPosition();
            }
          });

          window.__articleScrollRestorationBound = true;
        }

        restoreCurrentScrollPosition();
      })();
    </script>
    <script is:inline>
      (() => {
        const visibleScrollTop = 1400;
        const normalizePath = (pathname) => pathname.replace(/\/+$/, "") || "/";

        const supportsBackToTop = () => {
          const path = normalizePath(window.location.pathname);
          return path === "/articles" || path.startsWith("/articles/") || path === "/projects" || path.startsWith("/projects/");
        };

        const isRootScrollContainer = (scrollContainer) =>
          scrollContainer === document.scrollingElement ||
          scrollContainer === document.documentElement ||
          scrollContainer === document.body;

        const getPageScrollContainer = () => {
          const drawerContent = document.querySelector(".drawer-content");

          if (drawerContent instanceof HTMLElement) {
            const style = window.getComputedStyle(drawerContent);
            const canScroll = /(auto|scroll|overlay)/.test(style.overflowY);

            if (canScroll && drawerContent.scrollHeight > drawerContent.clientHeight) {
              return drawerContent;
            }
          }

          return document.scrollingElement ?? document.documentElement;
        };

        const getScrollTop = () => {
          const scrollContainer = getPageScrollContainer();

          if (isRootScrollContainer(scrollContainer)) {
            return window.scrollY;
          }

          return scrollContainer.scrollTop;
        };

        const updateBackToTopButton = () => {
          const button = document.querySelector("[data-back-to-top]");

          if (!(button instanceof HTMLButtonElement)) {
            return;
          }

          const shouldShow = supportsBackToTop() && getScrollTop() > visibleScrollTop;
          button.disabled = !shouldShow;
          button.tabIndex = shouldShow ? 0 : -1;
          button.classList.toggle("pointer-events-none", !shouldShow);
          button.classList.toggle("translate-y-3", !shouldShow);
          button.classList.toggle("scale-95", !shouldShow);
          button.classList.toggle("opacity-0", !shouldShow);
          button.classList.toggle("translate-y-0", shouldShow);
          button.classList.toggle("scale-100", shouldShow);
          button.classList.toggle("opacity-100", shouldShow);
          button.setAttribute("aria-hidden", shouldShow ? "false" : "true");
        };

        const scrollPageToTop = () => {
          const scrollContainer = getPageScrollContainer();

          if (isRootScrollContainer(scrollContainer)) {
            window.scrollTo({ top: 0, behavior: "smooth" });
            return;
          }

          scrollContainer.scrollTo({ top: 0, behavior: "smooth" });
        };

        const bindBackToTop = () => {
          const state = window.__backToTopState ?? {
            scrollTarget: null,
            clickBound: false,
          };
          const scrollContainer = getPageScrollContainer();
          const scrollTarget = isRootScrollContainer(scrollContainer) ? window : scrollContainer;

          if (state.scrollTarget !== scrollTarget) {
            state.scrollTarget?.removeEventListener("scroll", updateBackToTopButton);
            scrollTarget.addEventListener("scroll", updateBackToTopButton, { passive: true });
            state.scrollTarget = scrollTarget;
          }

          if (!state.clickBound) {
            document.addEventListener("click", (event) => {
              const target = event.target;

              if (!(target instanceof Element)) {
                return;
              }

              const button = target.closest("[data-back-to-top]");

              if (!(button instanceof HTMLButtonElement)) {
                return;
              }

              scrollPageToTop();
              button.blur();
            });
            state.clickBound = true;
          }

          window.__backToTopState = state;
          updateBackToTopButton();
        };

        if (!window.__backToTopLifecycleBound) {
          document.addEventListener("astro:page-load", bindBackToTop);
          document.addEventListener("astro:after-swap", bindBackToTop);
          window.addEventListener("resize", bindBackToTop);
          window.__backToTopLifecycleBound = true;
        }

        bindBackToTop();
      })();
    </script>
  </body>
</html>
