---
import { buildContributionSourceUrl } from "../data/github-contributions";

const username = "ethanz-code";
const profileUrl = `https://github.com/${username}`;
const sourceUrl = buildContributionSourceUrl(username);
const placeholderWeeks = Array.from({ length: 53 }, () => Array.from({ length: 7 }));
---

<section class="mb-16" data-contribution-chart data-contribution-src={sourceUrl}>
  <div class="mb-4 text-2xl font-bold leading-tight lg:text-4xl">今年的活跃状态</div>
  <p class="max-w-3xl leading-7 opacity-80" data-contribution-summary>GitHub 贡献数据加载中。</p>

  <div class="mt-6 overflow-x-auto rounded-lg border border-base-300 bg-base-100 p-4 shadow-sm sm:p-5 lg:p-6" data-contribution-scroll>
    <div class="min-w-[40rem] sm:min-w-[44rem] lg:min-w-[48rem]">
      <div class="flex items-end justify-between gap-6">
        <div>
          <div class="text-3xl font-bold sm:text-4xl lg:text-5xl" data-contribution-count>--</div>
          <div class="mt-2 text-sm opacity-60">contributions in the last year</div>
        </div>
        <a
          href={profileUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="link link-hover whitespace-nowrap text-sm opacity-70"
        >
          GitHub
        </a>
      </div>

      <div class="relative mt-8 h-6" data-contribution-months></div>

      <div class="mt-3 grid grid-flow-col grid-rows-7 gap-1" data-contribution-grid aria-busy="true">
        {
          placeholderWeeks.map((week) =>
            week.map(() => (
              <span
                class="contribution-cell contribution-cell--0 contribution-cell--loading h-3 w-3 rounded-[0.18rem]"
                aria-hidden="true"
              />
            ))
          )
        }
      </div>
    </div>
  </div>

  <div
    class="contribution-tooltip-layer pointer-events-none fixed left-0 top-0 z-[70] hidden max-w-[min(18rem,calc(100vw-1rem))] rounded-lg bg-neutral px-2 py-1 text-sm leading-tight text-neutral-content shadow-lg"
    data-contribution-tooltip-layer
    role="tooltip"
  ></div>
</section>

<script is:inline>
  (() => {
    const POSITION_GAP = 10;
    const VIEWPORT_PADDING = 8;
    const CELL_CLASS = "contribution-cell h-3 w-3 cursor-help rounded-[0.18rem]";

    const formatContributionTooltip = (date, count) => `${date} · ${count} 次提交`;

    const parseContributionCount = (doc) => {
      const heading = doc.querySelector("#js-contribution-activity-description");
      const matched = heading?.textContent?.match(/(\d[\d,]*)\s+contributions/i);

      if (!matched) {
        throw new Error("Unable to read GitHub contribution count.");
      }

      return Number.parseInt(matched[1].replaceAll(",", ""), 10);
    };

    const parseMonthLabels = (doc) => {
      const labels = [];
      let weekIndex = 0;

      doc.querySelectorAll(".ContributionCalendar-label").forEach((labelCell) => {
        const label = labelCell.querySelector("[aria-hidden='true']")?.textContent?.trim();
        const weekSpan = Number.parseInt(labelCell.getAttribute("colspan") || "0", 10);

        if (label && weekSpan > 0) {
          labels.push({ label, week: weekIndex });
          weekIndex += weekSpan;
        }
      });

      if (!labels.length) {
        throw new Error("Unable to read GitHub month labels.");
      }

      return labels;
    };

    const parseContributionCellCount = (tooltipText) => {
      if (tooltipText.startsWith("No contributions")) {
        return 0;
      }

      const matched = tooltipText.match(/(\d[\d,]*)\s+contributions?\s+on/i);

      if (!matched) {
        throw new Error(`Unable to parse contribution count from tooltip: ${tooltipText}`);
      }

      return Number.parseInt(matched[1].replaceAll(",", ""), 10);
    };

    const parseWeekData = (doc) => {
      const tooltipByCellId = new Map();

      doc.querySelectorAll("tool-tip[for]").forEach((tooltip) => {
        tooltipByCellId.set(tooltip.getAttribute("for"), tooltip.textContent.trim());
      });

      const weeks = new Map();

      doc.querySelectorAll("[data-date][data-level][id^='contribution-day-component-']").forEach((cell) => {
        const cellId = cell.id;
        const matched = cellId.match(/^contribution-day-component-(\d)-(\d+)$/);
        const date = cell.getAttribute("data-date");
        const level = Number.parseInt(cell.getAttribute("data-level") || "0", 10);
        const tooltipText = tooltipByCellId.get(cellId);

        if (!matched || !date || !tooltipText) {
          return;
        }

        const row = Number.parseInt(matched[1], 10);
        const week = Number.parseInt(matched[2], 10);
        const count = parseContributionCellCount(tooltipText);
        const weekDays = weeks.get(week) ?? new Map();

        weekDays.set(row, {
          count,
          date,
          level,
          tooltip: formatContributionTooltip(date, count),
        });

        weeks.set(week, weekDays);
      });

      if (!weeks.size) {
        throw new Error("Unable to read GitHub contribution grid.");
      }

      return [...weeks.entries()]
        .sort((left, right) => left[0] - right[0])
        .map(([, weekDays]) =>
          Array.from(
            { length: 7 },
            (_, row) =>
              weekDays.get(row) ?? {
                count: 0,
                date: "",
                isPlaceholder: true,
                level: 0,
                tooltip: "",
              },
          ),
        );
    };

    const parseContributionCalendar = (html) => {
      const doc = new DOMParser().parseFromString(html, "text/html");

      return {
        contributionCount: parseContributionCount(doc),
        monthLabels: parseMonthLabels(doc),
        weekData: parseWeekData(doc),
      };
    };

    const renderContributionCalendar = (chart, calendar) => {
      const summary = chart.querySelector("[data-contribution-summary]");
      const count = chart.querySelector("[data-contribution-count]");
      const months = chart.querySelector("[data-contribution-months]");
      const grid = chart.querySelector("[data-contribution-grid]");

      if (
        !(summary instanceof HTMLElement) ||
        !(count instanceof HTMLElement) ||
        !(months instanceof HTMLElement) ||
        !(grid instanceof HTMLElement)
      ) {
        return;
      }

      summary.textContent = `过去一年 GitHub 贡献 ${calendar.contributionCount} 次。`;
      count.textContent = String(calendar.contributionCount);
      months.replaceChildren();
      grid.replaceChildren();
      grid.removeAttribute("aria-busy");

      calendar.monthLabels.forEach((item, index) => {
        const label = document.createElement("span");

        label.className = "absolute top-0 whitespace-nowrap text-sm opacity-60";

        if (index === calendar.monthLabels.length - 1) {
          label.classList.add("-translate-x-full");
        }

        label.style.left = `calc(${(item.week / calendar.weekData.length) * 100}%)`;
        label.textContent = item.label;
        months.append(label);
      });

      calendar.weekData.forEach((week) => {
        week.forEach((day) => {
          const cell = document.createElement("span");

          cell.className = day.isPlaceholder
            ? "contribution-cell contribution-cell--placeholder h-3 w-3 rounded-[0.18rem]"
            : `${CELL_CLASS} contribution-cell--${day.level}`;

          if (day.isPlaceholder) {
            cell.setAttribute("aria-hidden", "true");
            grid.append(cell);
            return;
          }

          cell.dataset.contributionTooltip = day.tooltip;
          cell.setAttribute("aria-label", day.tooltip);
          cell.tabIndex = 0;
          grid.append(cell);
        });
      });
    };

    const renderContributionError = (chart) => {
      const summary = chart.querySelector("[data-contribution-summary]");
      const count = chart.querySelector("[data-contribution-count]");
      const grid = chart.querySelector("[data-contribution-grid]");

      if (summary instanceof HTMLElement) {
        summary.textContent = "GitHub 贡献数据暂时不可用。";
      }

      if (count instanceof HTMLElement) {
        count.textContent = "--";
      }

      if (grid instanceof HTMLElement) {
        grid.removeAttribute("aria-busy");
      }
    };

    const loadContributionCalendar = async (chart) => {
      if (!(chart instanceof HTMLElement) || chart.dataset.contributionLoaded === "true") {
        return;
      }

      const sourceUrl = chart.dataset.contributionSrc;

      if (!sourceUrl) {
        renderContributionError(chart);
        return;
      }

      chart.dataset.contributionLoaded = "true";

      try {
        const response = await fetch(sourceUrl);

        if (!response.ok) {
          throw new Error(`GitHub returned ${response.status}`);
        }

        const calendar = parseContributionCalendar(await response.text());

        renderContributionCalendar(chart, calendar);
      } catch (error) {
        console.warn("Unable to load GitHub contribution calendar.", error);
        renderContributionError(chart);
      }
    };

    const scheduleContributionLoading = () => {
      const loadAll = () => {
        document.querySelectorAll("[data-contribution-chart]").forEach((chart) => {
          if ("requestIdleCallback" in window) {
            window.requestIdleCallback(() => loadContributionCalendar(chart), { timeout: 2500 });
          } else {
            window.setTimeout(() => loadContributionCalendar(chart), 0);
          }
        });
      };

      if (document.readyState === "complete") {
        loadAll();
      } else {
        window.addEventListener("load", loadAll, { once: true });
      }
    };

    const bindContributionTooltip = (chart) => {
      if (!(chart instanceof HTMLElement) || chart.dataset.contributionTooltipBound === "true") {
        return;
      }

      const tooltipLayer = chart.querySelector("[data-contribution-tooltip-layer]");
      const scrollContainer = chart.querySelector("[data-contribution-scroll]");

      if (!(tooltipLayer instanceof HTMLElement)) {
        return;
      }

      let activeCell = null;

      const hideTooltip = () => {
        activeCell = null;
        tooltipLayer.classList.add("hidden");
        tooltipLayer.style.visibility = "";
        tooltipLayer.style.left = "";
        tooltipLayer.style.top = "";
      };

      const positionTooltip = (cell) => {
        const tooltipText = cell.dataset.contributionTooltip;

        if (!tooltipText) {
          hideTooltip();
          return;
        }

        activeCell = cell;
        tooltipLayer.textContent = tooltipText;
        tooltipLayer.classList.remove("hidden");
        tooltipLayer.style.visibility = "hidden";

        const cellRect = cell.getBoundingClientRect();
        const tooltipRect = tooltipLayer.getBoundingClientRect();
        const maxLeft = window.innerWidth - tooltipRect.width - VIEWPORT_PADDING;
        const centeredLeft = cellRect.left + cellRect.width / 2 - tooltipRect.width / 2;
        const left = Math.min(Math.max(centeredLeft, VIEWPORT_PADDING), Math.max(VIEWPORT_PADDING, maxLeft));
        const topAbove = cellRect.top - tooltipRect.height - POSITION_GAP;
        const topBelow = cellRect.bottom + POSITION_GAP;
        const top = topAbove >= VIEWPORT_PADDING ? topAbove : topBelow;

        tooltipLayer.style.left = `${left}px`;
        tooltipLayer.style.top = `${top}px`;
        tooltipLayer.style.visibility = "visible";
      };

      chart.addEventListener("mouseover", (event) => {
        const cell = event.target instanceof Element ? event.target.closest("[data-contribution-tooltip]") : null;

        if (cell instanceof HTMLElement) {
          positionTooltip(cell);
        }
      });

      chart.addEventListener("focusin", (event) => {
        const cell = event.target instanceof Element ? event.target.closest("[data-contribution-tooltip]") : null;

        if (cell instanceof HTMLElement) {
          positionTooltip(cell);
        }
      });

      chart.addEventListener("mouseout", (event) => {
        const cell = event.target instanceof Element ? event.target.closest("[data-contribution-tooltip]") : null;
        const nextTarget = event.relatedTarget instanceof Element
          ? event.relatedTarget.closest("[data-contribution-tooltip]")
          : null;

        if (cell && cell !== nextTarget) {
          hideTooltip();
        }
      });

      chart.addEventListener("focusout", hideTooltip);
      scrollContainer?.addEventListener("scroll", hideTooltip, { passive: true });
      window.addEventListener("scroll", hideTooltip, { passive: true });
      window.addEventListener("resize", () => {
        if (activeCell instanceof HTMLElement) {
          positionTooltip(activeCell);
        }
      });

      chart.dataset.contributionTooltipBound = "true";
    };

    const bindAllContributionTooltips = () => {
      document.querySelectorAll("[data-contribution-chart]").forEach(bindContributionTooltip);
    };

    bindAllContributionTooltips();
    scheduleContributionLoading();
    document.addEventListener("astro:after-swap", bindAllContributionTooltips);
    document.addEventListener("astro:after-swap", scheduleContributionLoading);
  })();
</script>

<style>
  :global([data-theme="light"]) {
    --contribution-level-0: #ebedf0;
    --contribution-level-1: #9be9a8;
    --contribution-level-2: #40c463;
    --contribution-level-3: #30a14e;
    --contribution-level-4: #216e39;
  }

  :global([data-theme="black"]) {
    --contribution-level-0: #2d333b;
    --contribution-level-1: #0e4429;
    --contribution-level-2: #006d32;
    --contribution-level-3: #26a641;
    --contribution-level-4: #39d353;
  }

  :global(.contribution-cell) {
    background-color: var(--contribution-cell-color);
  }

  :global(.contribution-cell--loading) {
    opacity: 0.72;
  }

  :global(.contribution-cell--placeholder) {
    opacity: 0;
  }

  :global(.contribution-cell--0) {
    --contribution-cell-color: var(--contribution-level-0);
  }

  :global(.contribution-cell--1) {
    --contribution-cell-color: var(--contribution-level-1);
  }

  :global(.contribution-cell--2) {
    --contribution-cell-color: var(--contribution-level-2);
  }

  :global(.contribution-cell--3) {
    --contribution-cell-color: var(--contribution-level-3);
  }

  :global(.contribution-cell--4) {
    --contribution-cell-color: var(--contribution-level-4);
  }
</style>
