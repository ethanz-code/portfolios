---
interface Props {
  href: string;
  title: string;
  description: string;
  eyebrow?: string;
}

const {
  href,
  title,
  description,
  eyebrow = "Project Resource",
} = Astro.props as Props;
---

<a
  class="not-prose group my-5 block border border-base-300 bg-base-100 p-4 no-underline transition hover:-translate-y-0.5 hover:border-base-content/30 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-base-content/40 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
>
  <span class="block text-xs font-semibold uppercase tracking-[0.12em] opacity-50">{eyebrow}</span>
  <span class="mt-2 block text-base font-bold leading-snug text-base-content sm:text-lg">{title}</span>
  <span class="mt-2 block text-sm leading-6 text-base-content/70">{description}</span>
</a>
