---
import { Image } from "astro:assets";

interface Props {
  src: string | ImageMetadata;
  alt: string;
  class?: string;
  widths?: number[];
  sizes?: string;
  width?: number;
  height?: number;
  format?: "avif" | "jpeg" | "png" | "webp";
  loading?: "eager" | "lazy";
}

const {
  src,
  alt,
  class: className,
  widths,
  sizes,
  width,
  height,
  format,
  loading,
} = Astro.props as Props;
---

{
  typeof src === "string" ? (
    <img src={src} alt={alt} class={className} loading={loading} />
  ) : (
    <Image
      src={src}
      alt={alt}
      class={className}
      widths={widths}
      sizes={sizes}
      width={width}
      height={height}
      format={format}
      loading={loading}
    />
  )
}
