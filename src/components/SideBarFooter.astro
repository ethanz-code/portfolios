---
import { Tv, Github, ScrollText, Globe } from "lucide-astro";

const socialLinks = [
  { href: "https://space.bilibili.com/483711690?spm_id_from=333.1007.0.0", label: "哔哩哔哩", icon: Tv },
  { href: "https://github.com/ethanz-code", label: "GitHub", icon: Github },
  { href: "https://cdn.itcox.cn/baseInfo/resume.pdf", label: "简历", icon: ScrollText },
  { href: "https://htlabs.com.cn", label: "官网", icon: Globe },
];
---

<div
  class="block sticky pointer-events-none bottom-10 bg-base-200 justify-center h-12 [mask-image:linear-gradient(transparent,#000000)]"
></div>

<div class="sticky bottom-0 bg-base-200 px-4 pb-5 pt-1 text-sm">
  <div class="flex items-center justify-center gap-1">
    {socialLinks.map((link) => (
      <a
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
        title={link.label}
        class:list={["btn btn-ghost btn-sm btn-square rounded-none", { "relative after:absolute after:-top-0.5 after:-right-0.5 after:h-1.5 after:w-1.5 after:rounded-full after:bg-primary": link.label === "简历" }]}
      >
        <link.icon size={16} />
      </a>
    ))}
  </div>
</div>
