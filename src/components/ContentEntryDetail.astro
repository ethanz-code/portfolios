---
import { type CollectionEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import MermaidRenderer from "./MermaidRenderer.astro";
import { type ArticleSchema, type ProjectSchema } from "../content.config";
import { contentProseClass } from "../lib/prose";
import aiDesignEffectDisplayImage from "../assets/projects/ai-design-aigc/effect-display.webp";
import newlandKnowledgeBaseImage from "../assets/projects/newland-iot-technical-services/knowledge-base.webp";
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";
import "dayjs/locale/zh-cn";

type Section = "articles" | "projects";
type ArticleEntry = CollectionEntry<"articles">;
type ProjectEntry = CollectionEntry<"projects">;

interface Props {
  section: Section;
  entry: ArticleEntry | ProjectEntry;
}

const { section, entry } = Astro.props;
const { Content } = await render(entry);
dayjs.extend(localizedFormat);
dayjs.locale("zh-cn");

const isArticle = section === "articles";
const article = isArticle ? entry.data as ArticleSchema : null;
const project = !isArticle ? entry.data as ProjectSchema : null;
const title = article?.title ?? project?.title ?? "";
const description = article?.description ?? (project?.visitorDescription || project?.description) ?? "";
const adminDescription = project?.description ?? "";
const projectImage = !isArticle && entry.id === "ai-design-aigc"
  ? aiDesignEffectDisplayImage
  : !isArticle && entry.id === "newland-iot-technical-services"
    ? newlandKnowledgeBaseImage
    : project?.heroImageLight ?? project?.heroImage;
const image = article?.heroImage ?? projectImage;
const backHref = isArticle ? "/articles" : "/projects";
const backLabel = isArticle ? "返回文章" : "返回项目";
const sideBarActiveItemID = section;
const ogType = isArticle ? "article" : undefined;
const displayDate = article
  ? dayjs(article.publishedDate).format("LL")
  : dayjs(project?.updatedDate).format("LL");
const updatedDate = article?.updatedDate ? dayjs(article.updatedDate).format("LL") : null;
const hasMermaid = entry.body?.includes("```mermaid") ?? false;
---

<BaseLayout title={title} description={description} image={image} sideBarActiveItemID={sideBarActiveItemID} ogType={ogType}>
  <main class="mx-auto w-full min-w-0 max-w-[760px]">
    <article class={contentProseClass}>
      <div class="not-prose mb-8">
        <div class="mb-6">
          <a href={backHref} class="btn btn-outline btn-sm gap-2">
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m15 18-6-6 6-6"></path>
            </svg>
            {backLabel}
          </a>
        </div>

        {
          isArticle && (
            <div class="mb-4 flex flex-wrap items-center gap-2">
              <span class="badge badge-neutral">文章</span>
            </div>
          )
        }

        <h1 class="m-0 break-words text-3xl font-bold leading-tight sm:text-4xl lg:text-5xl">{title}</h1>

        {
          isArticle ? (
            <p class="mt-4 text-base leading-7 opacity-80 sm:text-lg sm:leading-relaxed lg:text-xl">{description}</p>
          ) : (
            <>
              <p
                data-project-desc
                data-desc={adminDescription}
                data-visitor-desc={project?.visitorDescription || project?.description || ""}
                class="mt-4 text-base leading-7 opacity-80 sm:text-lg sm:leading-relaxed lg:text-xl"
              >
                {description}
              </p>
              {project?.tags && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {project.tags.map((tag) => <span class="badge badge-ghost">{tag}</span>)}
                </div>
              )}
            </>
          )
        }

        <div class="mt-3 text-sm opacity-60">
          {
            isArticle ? (
              <>
                发布于 <time>{displayDate}</time>
                {updatedDate && <span> · 更新于 <time>{updatedDate}</time></span>}
              </>
            ) : (
              <>
                更新于 <time>{displayDate}</time>
              </>
            )
          }
        </div>

        {
          isArticle && article?.tags && (
            <div class="mt-4 flex flex-wrap gap-2">
              {article.tags.map((tag) => <span class="badge badge-ghost">{tag}</span>)}
            </div>
          )
        }
      </div>

      <Content />

      {hasMermaid && <MermaidRenderer />}
    </article>
  </main>
</BaseLayout>

<script>
  function updateDetailDescription() {
    const params = new URLSearchParams(window.location.search);
    const isAdmin = params.get('admin') === 'true';
    
    const descEl = document.querySelector('[data-project-desc]');
    if (descEl) {
      const desc = descEl.getAttribute('data-desc') || '';
      const visitorDesc = descEl.getAttribute('data-visitor-desc') || desc;
      descEl.textContent = isAdmin ? desc : visitorDesc;
    }
  }
  
  updateDetailDescription();
  document.addEventListener('astro:page-load', updateDetailDescription);
</script>
