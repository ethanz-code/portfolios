---
import ThemeImage from "./ThemeImage.astro";

interface Props {
  title: string;
  img?: string | ImageMetadata;
  imgLight?: string | ImageMetadata;
  imgDark?: string | ImageMetadata;
  desc: string;
  url: string;
  target?: string;
  compactMobile?: boolean;
}

const { title, img, imgLight, imgDark, desc, url, target = "_blank", compactMobile = false } = Astro.props as Props;
---

<div
  class:list={[
    "project-card card w-full min-w-0 overflow-hidden border border-base-300/70 bg-base-100 shadow-sm transition ease-in-out md:border-0 md:shadow-none md:hover:scale-[102%] md:hover:shadow-xl",
    compactMobile && "project-card--compact-mobile",
  ]}
>
  <a class="block min-w-0" href={url} target={target}>
    <div class="card-body min-w-0 flex-col gap-0 p-0 md:flex-row md:items-center md:gap-4 md:p-5">
      {
        (imgLight || imgDark || img) && (
          <figure class="project-card__media w-full min-w-0 shrink-0 bg-base-200 md:w-auto md:bg-transparent">
            <ThemeImage
              light={imgLight ?? img}
              dark={imgDark}
              alt={title}
              class="h-full w-full object-cover object-left-top md:aspect-video md:h-auto md:w-[13rem] md:rounded-lg"
              width={750}
              height={422}
              format="webp"
              sizes="(max-width: 768px) 100vw, 13rem"
              widths={[320, 480, 750]}
              loading="lazy"
            />
          </figure>
        )
      }
      <div class="project-card__content w-full min-w-0 grow p-4 md:p-0">
        <div class="flex flex-wrap items-start gap-2.5">
          <h3 class="card-title min-w-0 break-words text-lg leading-snug sm:text-xl">{title}</h3>
        </div>
        <p class="project-card__description mt-2 text-base leading-7 break-words opacity-80 sm:text-[1.05rem] md:py-1 md:opacity-100">{desc}</p>
      </div>
    </div>
  </a>
</div>
