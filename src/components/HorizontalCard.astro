---
import ThemeImage from "./ThemeImage.astro";

interface Props {
  title: string;
  img?: string | ImageMetadata;
  imgLight?: string | ImageMetadata;
  imgDark?: string | ImageMetadata;
  desc: string;
  url: string;
  badge?: string;
  tags?: string[];
  target?: string;
}

const { title, img, imgLight, imgDark, desc, url, badge, tags, target = "_blank" } = Astro.props as Props;
const tag_url = url.split("/").slice(0, -1).join("/") + "/tag";
---

<div class="card bg-base-100 transition ease-in-out md:hover:scale-[102%] md:hover:shadow-xl">
  <a href={url} target={target}>
    <div class="card-body flex-col gap-4 p-4 sm:p-5 md:flex-row md:items-center">
      {
        (imgLight || imgDark || img) && (
          <figure class="w-full shrink-0 md:w-auto">
            <ThemeImage
              light={imgLight ?? img}
              dark={imgDark}
              alt={title}
              class="aspect-video w-full rounded-lg object-cover object-left-top md:w-[13rem]"
              width={750}
              height={422}
              format="webp"
              sizes="(max-width: 768px) 100vw, 13rem"
              widths={[320, 480, 750]}
              loading="lazy"
            />
          </figure>
        )
      }
      <div class="grow w-full min-w-0">
        <div class="flex flex-wrap items-start gap-2">
          <h2 class="card-title text-lg leading-snug sm:text-xl">{title}</h2>
          {badge && <div class="badge badge-secondary">{badge}</div>}
        </div>
        <p class="py-1 text-base leading-7 sm:text-[1.05rem]">{desc}</p>
        <div class="card-actions justify-end">
          {
            tags &&
              tags.map((tag) => (
                <a href={`${tag_url}/${tag}`} class="badge badge-ghost">
                  {tag}
                </a>
              ))
          }
        </div>
      </div>
    </div>
  </a>
</div>
